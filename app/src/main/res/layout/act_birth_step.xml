<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/layer_main"
    android:orientation="vertical">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:layout_width="@dimen/dp_40"
            android:layout_height="@dimen/dp_40"
            android:padding="@dimen/dp_5"
            android:id="@+id/iv_back"
            android:layout_marginStart="@dimen/dp_10"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:src="@drawable/iv_back"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STEP 1/4"
            app:layout_constraintTop_toTopOf="@+id/iv_back"
            app:layout_constraintBottom_toBottomOf="@+id/iv_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:textColor="@color/white"
            android:textSize="@dimen/sp_17"
            />

    </androidx.constraintlayout.widget.ConstraintLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/dp_25"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_50"
                android:text="What's your nickname?"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_20"
                 />


            <com.hjq.shape.view.ShapeEditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_15"
                app:shape_radius="@dimen/dp_12"
                android:padding="@dimen/dp_16"
                android:id="@+id/set_name"
                android:singleLine="true"
                android:maxLength="20"
                android:textColorHint="@color/color_929292"
                app:shape_solidColor="@color/inputColor"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_16" />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_30"
                android:text="What's your date of birth?"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_20"
                 />

            <TextView
                android:id="@+id/tv_female"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_5"
                android:text="You need to be 18 or older to register."
                android:textColor="@color/color_999999"
                android:textSize="@dimen/sp_12" />


            <com.hjq.shape.view.ShapeTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_15"
                app:shape_radius="@dimen/dp_12"
                android:padding="@dimen/dp_16"
                android:id="@+id/set_birth"
                android:singleLine="true"
                android:maxLength="20"
                android:hint="MM/DD/YYYY"
                android:textColorHint="@color/color_929292"
                android:textColor="@color/white"
                app:shape_solidColor="@color/inputColor"
                android:textSize="@dimen/sp_16" />

        </LinearLayout>

    <com.hjq.shape.view.ShapeTextView
        android:id="@+id/stv_next"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_25"
        android:layout_marginTop="@dimen/dp_18"
        android:layout_marginBottom="@dimen/dp_30"
        android:gravity="center"
        android:textStyle="bold"
        android:paddingVertical="@dimen/dp_16"
        android:text="Next"
        android:textColor="@color/color_333333"
        android:textSize="@dimen/sp_20"
        app:shape_radius="@dimen/dp_30"
        app:shape_solidGradientStartColor="@color/startGradientColor"
        app:shape_solidGradientEndColor="@color/endGradientColor"
        app:shape_solidPressedColor="@color/pressed_color_light" />
</LinearLayout>