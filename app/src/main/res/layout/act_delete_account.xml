<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.chat.jolt.widget.MToolBar
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:title="Delete Account" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <com.hjq.shape.layout.ShapeLinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/dp_16"
            android:orientation="vertical"
            android:padding="@dimen/dp_24"
            app:shape_radius="@dimen/dp_12"
            app:shape_solidColor="@color/white_20">


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔄  Data Retention"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_20"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_15"
                android:lineSpacingExtra="@dimen/dp_20"
                android:text="Your data is retained for 30 days after account deletion. After this period, it’s permanently deleted or anonymized in line with our data retention policy."
                android:textColor="@color/color_999999"
                android:textSize="@dimen/sp_15" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_32"
                android:text="♻️ Account Reactivation"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_20"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_15"
                android:lineSpacingExtra="@dimen/dp_20"
                android:text="Log in within 30 days of deletion to reactivate and restore your account."
                android:textColor="@color/color_999999"
                android:textSize="@dimen/sp_15" />


        </com.hjq.shape.layout.ShapeLinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">


        <com.hjq.shape.view.ShapeTextView
            android:id="@+id/stv_delete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dp_20"
            android:layout_marginTop="@dimen/dp_24"
            android:enabled="false"
            android:gravity="center"
            android:paddingVertical="@dimen/dp_16"
            android:text="Delete Account"
            android:textColor="@color/firstTextColor"
            android:textSize="@dimen/sp_18"
            app:layout_constraintTop_toBottomOf="@+id/set_emails"
            app:shape_radius="@dimen/dp_29"
            app:shape_solidDisabledColor="@color/color_4A4A4A"
            app:shape_solidGradientEndColor="@color/endGradientColor"
            app:shape_solidGradientStartColor="@color/startGradientColor"
            app:shape_solidPressedColor="@color/pressed_color_light"
            app:shape_textDisabledColor="@color/white" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_24"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingBottom="@dimen/dp_12">

            <LinearLayout
                android:id="@+id/ll_check"
                android:layout_width="@dimen/dp_35"
                android:layout_height="@dimen/dp_35"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="@dimen/dp_3">

                <CheckBox
                    android:id="@+id/cb_check"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/selector_check"
                    android:button="@null"
                    android:checked="false"
                    android:clickable="false" />
            </LinearLayout>


            <TextView
                android:id="@+id/tv_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="I understand the consequences and wish to proceed"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_12" />


        </LinearLayout>
    </LinearLayout>

</LinearLayout>