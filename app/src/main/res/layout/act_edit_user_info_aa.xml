<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:background="@color/appColor"
    android:layout_height="match_parent">

    <com.chat.jolt.widget.MToolBar
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        android:id="@+id/toolbar"
        app:title="Edit Profile" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="@+id/toolbar"
        app:layout_constraintBottom_toBottomOf="@id/toolbar"
        app:layout_constraintEnd_toEndOf="parent"
        android:id="@+id/ll_save"
        android:orientation="horizontal">

        <com.hjq.shape.view.ShapeTextView
            android:id="@+id/tv_save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/dp_15"
            android:gravity="center"
            android:paddingHorizontal="@dimen/dp_13"
            android:paddingVertical="@dimen/dp_5"
            android:textColor="@color/white"
            android:text="Save"
            android:textStyle="bold"
            android:textSize="@dimen/sp_14"
            app:shape_radius="@dimen/dp_12"
            app:shape_solidPressedColor="@color/pressed_color_light"
            app:shape_solidColor="@color/color_FF4455"
            app:layout_constraintTop_toTopOf="@+id/toolbar"
            app:layout_constraintBottom_toBottomOf="@id/toolbar"
            app:layout_constraintEnd_toEndOf="parent" />
    </LinearLayout>



    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="@dimen/dp_46"
                android:fontFamily="@font/arial_black"
                android:gravity="center"
                android:paddingHorizontal="15dp"
                android:text="Photo Album"
                android:textColor="@color/color_151515"
                android:textSize="@dimen/sp_18" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/picture_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:overScrollMode="never"
                android:layout_marginHorizontal="@dimen/dp_10"
                app:spanCount="3" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="@dimen/dp_46"
                android:layout_marginTop="7.5dp"
                android:fontFamily="@font/arial_black"
                android:gravity="center"
                android:paddingHorizontal="15dp"
                android:text="Basics"
                android:textColor="@color/color_151515"
                android:textSize="@dimen/sp_18" />

            <com.hjq.shape.layout.ShapeLinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dp_15"
                android:layout_marginTop="@dimen/dp_10"
                android:gravity="center_vertical"
                android:orientation="vertical"
                app:shape_radius="@dimen/dp_10"
                app:shape_solidColor="@color/color_E9E5DA">

                <com.chat.jolt.widget.InfoItemView
                    app:itvTitle="Nickname"
                    android:id="@+id/ivt_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <com.chat.jolt.widget.InfoItemView
                    app:itvTitle="Profile Photo"
                    android:id="@+id/ivt_avatar"
                    app:itvImgVisible="true"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <com.chat.jolt.widget.InfoItemView
                    app:itvTitle="Date of Birth"
                    android:id="@+id/ivt_birth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <com.chat.jolt.widget.InfoItemView
                    app:itvTitle="Zodiac Sign"
                    android:id="@+id/ivt_zodiac"
                    app:itvIntoImgVisible="false"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <com.chat.jolt.widget.InfoItemView
                    app:itvTitle="Weight"
                    android:id="@+id/ivt_weight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <com.chat.jolt.widget.InfoItemView
                    app:itvTitle="Height"
                    android:id="@+id/ivt_height"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <com.chat.jolt.widget.InfoItemView
                    app:itvTitle="Career"
                    android:id="@+id/ivt_career"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>



            </com.hjq.shape.layout.ShapeLinearLayout>


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="@dimen/dp_46"
                android:layout_marginTop="@dimen/dp_10"
                android:fontFamily="@font/arial_black"
                android:gravity="center"
                android:paddingHorizontal="15dp"
                android:text="About Me"
                android:textColor="@color/color_151515"
                android:textSize="@dimen/sp_18" />
            <com.hjq.shape.layout.ShapeLinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dp_15"
                android:layout_marginTop="@dimen/dp_10"
                android:gravity="center_vertical"
                android:orientation="vertical"
                app:shape_radius="@dimen/dp_10"
                app:shape_solidColor="@color/color_E9E5DA">

            <com.chat.jolt.widget.InfoItemView
                app:itvTitle="Self Introduction"
                app:itvContent="Add"
                android:id="@+id/ivt_introduction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            </com.hjq.shape.layout.ShapeLinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="@dimen/dp_46"
                android:layout_marginTop="@dimen/dp_10"
                android:fontFamily="@font/arial_black"
                android:gravity="center"
                android:paddingHorizontal="15dp"
                android:text="Now I Want ..."
                android:textColor="@color/color_151515"
                android:textSize="@dimen/sp_18" />

            <com.hjq.shape.layout.ShapeLinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dp_15"
                android:layout_marginTop="@dimen/dp_10"
                android:gravity="center_vertical"
                android:orientation="vertical"
                app:shape_radius="@dimen/dp_10"
                app:shape_solidColor="@color/color_E9E5DA">
            <com.chat.jolt.widget.InfoItemView
                app:itvTitle=""
                android:id="@+id/ivt_want"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            </com.hjq.shape.layout.ShapeLinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_10"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:fontFamily="@font/arial_black"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="15dp"
                    android:text="My interests"
                    android:layout_weight="1"
                    android:textColor="@color/color_151515"
                    android:textSize="@dimen/sp_18" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/iv_add_interest"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/dp_46"
                    android:paddingHorizontal="@dimen/dp_15"
                    android:src="@drawable/iv_add_interest" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/label_recycler_view"
                android:overScrollMode="never"
                android:nestedScrollingEnabled="false"
                android:layout_width="match_parent"
                android:layout_marginStart="@dimen/dp_15"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_14" />


        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
