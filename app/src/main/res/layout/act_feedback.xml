<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/appColor"
    android:orientation="vertical">


    <com.chat.jolt.widget.MToolBar
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:title="Feedback" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dp_15"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="@dimen/dp_15"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textStyle="bold"
                        android:text="Describe details"
                        android:textColor="@color/white"
                        android:textSize="@dimen/sp_16"
                         />

                    <TextView
                        android:id="@+id/tv_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/500"
                        android:textColor="@color/white"
                        android:textSize="@dimen/sp_12" />
                </LinearLayout>

                <com.hjq.shape.view.ShapeEditText
                    android:id="@+id/set_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_14"
                    android:background="@null"
                    android:gravity="top"
                    android:hint="Please describe the details of the feedback"
                    android:maxLength="500"
                    android:minLines="7"
                    android:textStyle="bold"
                    android:paddingHorizontal="@dimen/dp_12"
                    android:paddingVertical="@dimen/dp_15"
                    android:textColor="@color/white"
                    android:textColorHint="@color/color_999999"
                    android:textSize="@dimen/sp_14"
                    app:shape_solidColor="@color/color_36343A"
                    app:shape_radius="@dimen/dp_15"
                     />


            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dp_15"
                android:layout_marginTop="@dimen/dp_20"
                android:text="Contact Email（optional）"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="@dimen/sp_16"
                />

            <com.hjq.shape.view.ShapeEditText
                android:id="@+id/set_emails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dp_15"
                android:layout_marginTop="@dimen/dp_15"
                android:gravity="top"
                android:minLines="5"
                android:maxLength="50"
                android:hint="Please enter your Email"
                android:textStyle="bold"
                android:paddingHorizontal="@dimen/dp_12"
                android:paddingVertical="@dimen/dp_15"
                android:textColor="@color/white"
                android:textColorHint="@color/color_999999"
                android:textSize="@dimen/sp_15"
                app:shape_solidColor="@color/color_36343A"
                app:shape_radius="@dimen/dp_15"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_0"
                android:layout_weight="1" />

            <com.hjq.shape.view.ShapeTextView
                android:id="@+id/stv_next"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dp_20"
                android:gravity="center"
                android:paddingVertical="@dimen/dp_13"
                android:text="Submit"
                android:enabled="false"
                android:layout_marginBottom="@dimen/dp_15"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_18"
                app:shape_radius="@dimen/dp_29"
                app:shape_solidColor="@color/color_EAA82B"
                app:shape_solidDisabledColor="@color/color_C5C5C5"
                app:shape_solidPressedColor="@color/pressed_color_light"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
