<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.chat.jolt.widget.MToolBar
        android:id="@+id/mToolBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:title="Feedback" />

    <TextView
        android:id="@+id/tv_0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_15"
        android:layout_marginTop="@dimen/dp_16"
        android:text="Describe details"
        android:textColor="@color/white"
        android:textSize="@dimen/sp_16"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/mToolBar" />

    <com.hjq.shape.view.ShapeEditText
        android:id="@+id/set_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_15"
        android:layout_marginTop="@dimen/dp_14"
        android:background="@null"
        android:gravity="top"
        app:shape_strokeColor="@color/white_50"
        app:shape_strokeSize="@dimen/dp_1"
        android:hint="Please describe the details of the feedback"
        android:maxLength="500"
        android:minLines="7"
        android:paddingHorizontal="@dimen/dp_12"
        android:paddingVertical="@dimen/dp_15"
        android:textColor="@color/white"
        android:textColorHint="@color/white_50"
        android:textSize="@dimen/sp_14"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/tv_0"
        app:shape_radius="@dimen/dp_15"
        app:shape_solidColor="@color/color_4A4A4A" />

    <TextView
        android:id="@+id/tv_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0/500"
        android:textColor="@color/white_50"
        android:textSize="@dimen/sp_12"
        android:layout_marginEnd="@dimen/dp_16"
        android:layout_marginBottom="@dimen/dp_16"
        app:layout_constraintBottom_toBottomOf="@+id/set_text"
        app:layout_constraintEnd_toEndOf="@+id/set_text" />

    <TextView
        android:id="@+id/tv_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_15"
        android:layout_marginTop="@dimen/dp_24"
        android:text="Contact Email（optional）"
        android:textColor="@color/white"
        android:textSize="@dimen/sp_16"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/set_text" />

    <com.hjq.shape.view.ShapeEditText
        android:id="@+id/set_emails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_15"
        android:layout_marginTop="@dimen/dp_15"
        android:gravity="top"
        android:hint="Please enter your Email"
        android:maxLength="50"
        android:minLines="1"
        app:shape_strokeColor="@color/white_50"
        app:shape_strokeSize="@dimen/dp_1"
        android:paddingHorizontal="@dimen/dp_12"
        android:paddingVertical="@dimen/dp_16"
        android:textColor="@color/white"
        android:textColorHint="@color/white_50"
        android:textSize="@dimen/sp_15"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/tv_2"
        app:shape_radius="@dimen/dp_15"
        app:shape_solidColor="@color/color_4A4A4A" />


    <com.hjq.shape.view.ShapeTextView
        android:id="@+id/stv_next"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_32"
        android:layout_marginTop="@dimen/dp_24"
        android:enabled="false"
        android:gravity="center"
        android:paddingVertical="@dimen/dp_16"
        android:text="Submit"
        android:textColor="@color/firstTextColor"
        app:shape_textDisabledColor="@color/white"
        android:textSize="@dimen/sp_18"
        app:layout_constraintTop_toBottomOf="@+id/set_emails"
        app:shape_radius="@dimen/dp_29"
        app:shape_solidGradientStartColor="@color/startGradientColor"
        app:shape_solidGradientEndColor="@color/endGradientColor"
        app:shape_solidDisabledColor="@color/color_4A4A4A"
        app:shape_solidPressedColor="@color/pressed_color_light" />
</androidx.constraintlayout.widget.ConstraintLayout>
