<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/layer_main"
    android:orientation="vertical">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:layout_width="@dimen/dp_40"
            android:layout_height="@dimen/dp_40"
            android:padding="@dimen/dp_5"
            android:id="@+id/iv_back"
            android:layout_marginStart="@dimen/dp_10"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:src="@drawable/iv_back"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STEP 4/4"
            app:layout_constraintTop_toTopOf="@+id/iv_back"
            app:layout_constraintBottom_toBottomOf="@+id/iv_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:textColor="@color/white"
            android:textSize="@dimen/sp_17"
            />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/dp_25"
            app:layout_constraintTop_toTopOf="parent">



            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_20"
                android:text="Select your Photos"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_20"
                />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_5"
                android:text="Please share a captivating Photo of Yourself"
                android:textColor="@color/color_999999"
                android:textSize="@dimen/sp_12" />


            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/picture_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_15"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                tools:itemCount="1"
                tools:listitem="@layout/item_cover_photo" />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_30"
                android:text="Build Your Vibe"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_20"
                />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_5"
                android:text="The more you share, the better we pair!"
                android:textColor="@color/color_999999"
                android:textSize="@dimen/sp_12" />


            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_15"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_hobby_step" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>




    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_18"
        android:layout_marginHorizontal="@dimen/dp_25"
        android:orientation="horizontal">

        <com.hjq.shape.view.ShapeTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Skip"
            android:layout_gravity="end"
            android:textStyle="bold"
            android:id="@+id/tv_skip"
            android:layout_marginEnd="@dimen/dp_15"
            app:shape_radius="@dimen/dp_30"
            app:shape_strokeColor="@color/white"
            app:shape_strokeSize="@dimen/dp_2"
            android:layout_marginTop="@dimen/dp_20"
            android:paddingVertical="@dimen/dp_16"
            android:paddingHorizontal="@dimen/dp_31"
            android:textColor="@color/white"
            android:textSize="@dimen/sp_20"
            />
        <com.hjq.shape.view.ShapeTextView
            android:id="@+id/stv_next"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:layout_marginBottom="@dimen/dp_30"
            android:enabled="true"
            android:gravity="center"
            android:paddingVertical="@dimen/dp_16"
            android:text="Done"
            android:textStyle="bold"
            android:textColor="@color/firstTextColor"
            android:textSize="@dimen/sp_20"
            app:shape_radius="@dimen/dp_30"
            app:shape_solidGradientStartColor="@color/startGradientColor"
            app:shape_solidGradientEndColor="@color/endGradientColor"
            app:shape_solidPressedColor="@color/pressed_color_light" />
    </LinearLayout>


</LinearLayout>