<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/layer_main"
    android:orientation="vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <com.chat.jolt.widget.MToolBar
            android:id="@+id/appToolBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent" />


        <TextView
            android:id="@+id/tv_0"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dp_20"
            android:layout_marginTop="@dimen/dp_90"
            android:text="Login With Email"
            android:textColor="@color/white"
            android:textSize="@dimen/sp_20"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <com.hjq.shape.layout.ShapeLinearLayout
            android:id="@+id/sll_0"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dp_20"
            android:layout_marginTop="@dimen/dp_16"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_0"
            app:shape_radius="@dimen/dp_12"
            app:shape_solidColor="@color/inputColor">


            <com.hjq.shape.view.ShapeEditText
                android:id="@+id/et_account"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Email address"
                android:maxLength="64"
                android:paddingHorizontal="@dimen/dp_15"
                android:paddingVertical="@dimen/dp_16"
                android:singleLine="true"
                android:textColor="@color/white"
                android:textColorHint="@color/color_929292"
                android:textSize="@dimen/sp_16" />

            <ImageView
                android:id="@+id/iv_email_clear"
                android:layout_width="@dimen/dp_24"
                android:layout_height="match_parent"
                android:layout_marginEnd="@dimen/dp_15"
                android:padding="@dimen/dp_2"
                android:src="@drawable/iv_email_clear"
                android:visibility="gone" />

        </com.hjq.shape.layout.ShapeLinearLayout>


        <TextView
            android:id="@+id/tv_email_notice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dp_20"
            android:layout_marginTop="@dimen/dp_5"
            android:text="*Please ensure the email is correct."
            android:textColor="@color/color_FFE388"
            android:textSize="@dimen/sp_12"
            android:visibility="invisible"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/sll_0" />

        <com.hjq.shape.layout.ShapeLinearLayout
            android:id="@+id/sll_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dp_20"
            android:layout_marginTop="@dimen/dp_10"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_email_notice"
            app:shape_radius="@dimen/dp_12"
            app:shape_solidColor="@color/inputColor">

            <com.hjq.shape.view.ShapeEditText
                android:id="@+id/et_password"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Enter Password"
                android:inputType="textPassword"
                android:maxLength="64"
                android:paddingHorizontal="@dimen/dp_15"
                android:paddingVertical="@dimen/dp_16"
                android:textColor="@color/white"
                android:textColorHint="@color/color_B5B5B5"
                android:textSize="@dimen/sp_16" />

            <ImageView
                android:id="@+id/iv_password_eyes"
                android:layout_width="@dimen/dp_24"
                android:layout_height="match_parent"
                android:layout_marginEnd="@dimen/dp_15"
                android:padding="@dimen/dp_2"
                android:src="@drawable/iv_no_eyes"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/iv_password_clear"
                android:layout_width="@dimen/dp_24"
                android:layout_height="match_parent"
                android:layout_marginEnd="@dimen/dp_15"
                android:padding="@dimen/dp_2"
                android:src="@drawable/iv_email_clear"
                android:visibility="gone" />
        </com.hjq.shape.layout.ShapeLinearLayout>

        <TextView
            android:id="@+id/tv_password_notice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dp_20"
            android:layout_marginTop="@dimen/dp_5"
            android:text="*Wrong password, Please re-enter"
            android:textColor="@color/color_FFE388"
            android:textSize="@dimen/sp_12"
            android:visibility="invisible"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/sll_1" />

        <com.hjq.shape.view.ShapeTextView
            android:id="@+id/stv_login"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dp_25"
            android:layout_marginTop="@dimen/dp_40"
            android:enabled="false"
            android:gravity="center"
            android:paddingVertical="@dimen/dp_16"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_password_notice"
            android:text="Login"
            android:textColor="@color/color_333333"
            android:textSize="@dimen/sp_20"
            app:shape_radius="@dimen/dp_30"
            android:alpha="0.3"
            app:shape_solidGradientStartColor="@color/startGradientColor"
            app:shape_solidGradientEndColor="@color/endGradientColor"
            app:shape_solidPressedColor="@color/pressed_color_light">


        </com.hjq.shape.view.ShapeTextView>


        <com.hjq.shape.layout.ShapeRecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="0dp"
            android:layout_height="@dimen/dp_250"
            android:layout_marginTop="@dimen/dp_5"
            android:overScrollMode="never"
            android:visibility="gone"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintEnd_toEndOf="@id/sll_0"
            app:layout_constraintStart_toStartOf="@+id/sll_0"
            app:layout_constraintTop_toBottomOf="@id/sll_0"
            app:shape_radius="@dimen/dp_10"
            app:shape_strokeColor="@color/white"
            app:shape_strokeSize="@dimen/dp_1"
            app:shape_solidColor="@color/color_161616"
            tools:listitem="@layout/item_email_menu" />

    </androidx.constraintlayout.widget.ConstraintLayout>


    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:src="@drawable/iv_or" />


    <com.hjq.shape.layout.ShapeLinearLayout
        android:id="@+id/sll_google_login"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_20"
        android:layout_marginTop="@dimen/dp_20"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingVertical="@dimen/dp_16"
        android:layout_marginBottom="@dimen/dp_20"
        app:layout_constraintBottom_toTopOf="@+id/sll_email_login"
        app:shape_radius="@dimen/dp_30"
        app:shape_strokeSize="@dimen/dp_1"
        app:shape_strokeColor="@color/white"
        app:shape_solidPressedColor="@color/pressed_color_light">

        <ImageView
            android:layout_width="@dimen/dp_26"
            android:layout_height="@dimen/dp_26"
            android:layout_marginEnd="@dimen/dp_10"
            android:src="@drawable/iv_google" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:fontFamily="@font/rany_b"
            android:text="Login with Google"
            android:textColor="@color/white"
            android:textSize="@dimen/sp_16" />

    </com.hjq.shape.layout.ShapeLinearLayout>

</LinearLayout>