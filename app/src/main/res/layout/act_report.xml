<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/appColor"
    android:orientation="vertical">


    <com.chat.jolt.widget.MToolBar
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:title="Report" />


    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dp_20"
                android:layout_marginTop="@dimen/dp_15"
                android:text="Choose the reason"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_16"
                android:textStyle="bold" />


            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_15"
                android:layout_marginEnd="@dimen/dp_20"
                tools:itemCount="3"
                tools:listitem="@layout/item_report" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dp_10"
                android:layout_marginTop="@dimen/dp_10"
                android:orientation="vertical"
                android:padding="@dimen/dp_10">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Describe Details"
                            android:textColor="@color/white"
                            android:textSize="@dimen/sp_16"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <com.hjq.shape.view.ShapeEditText
                        android:id="@+id/set_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_14"
                        android:background="@null"
                        android:gravity="top"
                        android:hint="Please describe the details of the feedback"
                        android:maxLength="500"
                        android:minLines="8"
                        android:paddingHorizontal="@dimen/dp_12"
                        android:paddingVertical="@dimen/dp_15"
                        android:textColor="@color/white"
                        android:textColorHint="@color/color_999999"
                        android:textSize="@dimen/sp_14"
                        android:textStyle="bold"
                        app:shape_radius="@dimen/dp_10"
                        app:shape_solidColor="@color/color_36343A" />

                </LinearLayout>


            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_0"
                android:layout_weight="1" />


            <com.hjq.shape.view.ShapeTextView
                android:id="@+id/stv_next"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dp_20"
                android:layout_marginBottom="@dimen/dp_15"
                android:enabled="false"
                android:gravity="center"
                android:paddingVertical="@dimen/dp_13"
                android:text="Confirm"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_18"
                app:shape_radius="@dimen/dp_29"
                app:shape_solidColor="@color/color_EAA82B"
                app:shape_solidDisabledColor="@color/color_C5C5C5"
                app:shape_solidPressedColor="@color/pressed_color_light" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>