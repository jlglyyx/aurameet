<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/appColor"
    android:orientation="vertical">

    <com.chat.jolt.widget.MToolBar
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:title="Settings" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">


        <com.hjq.shape.layout.ShapeLinearLayout
            android:id="@+id/sll_account"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dp_15"
            android:layout_marginTop="@dimen/dp_10"
            android:clickable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/dp_18"
            android:paddingVertical="@dimen/dp_17"
            app:shape_radius="@dimen/dp_8"
            app:shape_solidColor="@color/color_36343A"
            app:shape_solidPressedColor="@color/pressed_color_light">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Account"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_16"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/color_999999"
                android:textIsSelectable="true"
                android:textSize="@dimen/sp_14" />

        </com.hjq.shape.layout.ShapeLinearLayout>


        <com.hjq.shape.layout.ShapeLinearLayout
            android:id="@+id/sll_agreement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dp_15"
            android:layout_marginTop="@dimen/dp_10"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="@dimen/dp_15"
            android:paddingStart="@dimen/dp_18"
            android:paddingEnd="@dimen/dp_8"
            app:shape_radiusInTopLeft="@dimen/dp_8"
            app:shape_radiusInTopRight="@dimen/dp_8"
            app:shape_solidColor="@color/color_36343A"
            app:shape_solidPressedColor="@color/pressed_color_light">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="User Agreement"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_16"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="@dimen/dp_25"
                android:layout_height="@dimen/dp_25"
                android:src="@drawable/iv_into" />

        </com.hjq.shape.layout.ShapeLinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_0_1"
            android:layout_marginHorizontal="@dimen/dp_15"
            android:background="@color/color_545257" />

        <com.hjq.shape.layout.ShapeLinearLayout
            android:id="@+id/sll_privacy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dp_15"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="@dimen/dp_15"
            android:paddingStart="@dimen/dp_18"
            android:paddingEnd="@dimen/dp_8"
            app:shape_radiusInBottomLeft="@dimen/dp_8"
            app:shape_radiusInBottomRight="@dimen/dp_8"
            app:shape_solidColor="@color/color_36343A"
            app:shape_solidPressedColor="@color/pressed_color_light">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Privacy Policy"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_16"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="@dimen/dp_25"
                android:layout_height="@dimen/dp_25"
                android:src="@drawable/iv_into" />

        </com.hjq.shape.layout.ShapeLinearLayout>


        <com.hjq.shape.layout.ShapeLinearLayout
            android:id="@+id/sll_delete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dp_15"
            android:layout_marginTop="@dimen/dp_10"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="@dimen/dp_15"
            android:paddingStart="@dimen/dp_18"
            android:paddingEnd="@dimen/dp_8"
            app:shape_radiusInTopLeft="@dimen/dp_8"
            app:shape_radiusInTopRight="@dimen/dp_8"
            app:shape_solidColor="@color/color_36343A"
            app:shape_solidPressedColor="@color/pressed_color_light">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Delete Account"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_16"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="@dimen/dp_25"
                android:layout_height="@dimen/dp_25"
                android:src="@drawable/iv_into" />


        </com.hjq.shape.layout.ShapeLinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_0_1"
            android:layout_marginHorizontal="@dimen/dp_15"
            android:background="@color/color_545257" />


        <com.hjq.shape.layout.ShapeLinearLayout
            android:id="@+id/sll_login_out"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dp_15"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="@dimen/dp_15"
            android:paddingStart="@dimen/dp_18"
            android:paddingEnd="@dimen/dp_8"
            app:shape_radiusInBottomLeft="@dimen/dp_8"

            app:shape_radiusInBottomRight="@dimen/dp_8"
            app:shape_solidColor="@color/color_36343A"
            app:shape_solidPressedColor="@color/pressed_color_light">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Logout"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_16"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="@dimen/dp_25"
                android:layout_height="@dimen/dp_25"
                android:src="@drawable/iv_into" />

        </com.hjq.shape.layout.ShapeLinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_0_1"
            android:layout_marginHorizontal="@dimen/dp_15"
            android:background="@color/white_20" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dp_10"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="service@jolt-chat.com"
            android:textColor="@color/color_EAA82B"
            android:id="@+id/tv_bottom_email"
            android:textSize="@dimen/sp_12" />

        <TextView
            android:id="@+id/tv_version_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_5"
            android:textColor="@color/white"
            android:textColorHighlight="@color/color_999999"
            android:textSize="@dimen/sp_12" />

    </LinearLayout>

</LinearLayout>