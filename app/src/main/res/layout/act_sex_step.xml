<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@drawable/layer_main"
    android:orientation="vertical">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:layout_width="@dimen/dp_40"
            android:layout_height="@dimen/dp_40"
            android:padding="@dimen/dp_5"
            android:id="@+id/iv_back"
            android:layout_marginStart="@dimen/dp_10"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:src="@drawable/iv_back"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STEP 2/4"
            app:layout_constraintTop_toTopOf="@+id/iv_back"
            app:layout_constraintBottom_toBottomOf="@+id/iv_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:textColor="@color/white"
            android:textSize="@dimen/sp_17"
            />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"

            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_50"
                android:layout_marginHorizontal="@dimen/dp_25"
                android:text="What's your gender?"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_20"
                 />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_5"
                android:layout_marginHorizontal="@dimen/dp_25"
                android:text="Tell us which gender best describes you."
                android:textColor="@color/color_999999"
                android:textSize="@dimen/sp_13" />


            <com.hjq.shape.layout.ShapeLinearLayout
                android:id="@+id/ll_male"
                android:layout_marginHorizontal="@dimen/dp_25"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/dp_20"
                android:gravity="center"
                app:shape_strokeColor="@color/white"
                app:shape_strokeSize="@dimen/dp_1"
                app:shape_radius="@dimen/dp_10"
                android:layout_marginTop="@dimen/dp_10"
                android:orientation="horizontal">


                <TextView
                    android:id="@+id/tv_male"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="I'm a man"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:textSize="@dimen/sp_16" />


                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_male"
                    app:shapeAppearance="@style/circleStyle"
                    android:layout_width="@dimen/dp_20"
                    android:layout_height="@dimen/dp_20"
                    />

            </com.hjq.shape.layout.ShapeLinearLayout>
            <com.hjq.shape.layout.ShapeLinearLayout
                android:id="@+id/ll_female"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/dp_20"
                android:gravity="center"
                android:layout_marginHorizontal="@dimen/dp_25"
                app:shape_strokeColor="@color/white"
                app:shape_strokeSize="@dimen/dp_1"
                app:shape_radius="@dimen/dp_10"
                android:layout_marginTop="@dimen/dp_15"
                android:orientation="horizontal">


                <TextView
                    android:id="@+id/tv_female"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="I'm a Woman"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:textSize="@dimen/sp_16" />


                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_female"
                    app:shapeAppearance="@style/circleStyle"
                    android:layout_width="@dimen/dp_20"
                    android:layout_height="@dimen/dp_20"
                    />

            </com.hjq.shape.layout.ShapeLinearLayout>

            <com.hjq.shape.layout.ShapeLinearLayout
                android:id="@+id/ll_other"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/dp_20"
                android:gravity="center"
                android:layout_marginHorizontal="@dimen/dp_25"
                app:shape_strokeColor="@color/white"
                app:shape_strokeSize="@dimen/dp_1"
                app:shape_radius="@dimen/dp_10"
                android:layout_marginTop="@dimen/dp_15"
                android:orientation="horizontal">


                <TextView
                    android:id="@+id/tv_other"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="I'm a Non-binary"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:textSize="@dimen/sp_16" />


                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_other"
                    app:shapeAppearance="@style/circleStyle"
                    android:layout_width="@dimen/dp_20"
                    android:layout_height="@dimen/dp_20"
                    />

            </com.hjq.shape.layout.ShapeLinearLayout>




            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_30"
                android:id="@+id/tv_0"
                android:visibility="gone"
                android:text="What body shape you prefer？"
                android:textColor="@color/white"
                android:layout_marginHorizontal="@dimen/dp_25"
                android:textSize="@dimen/sp_20"
               />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_5"
                android:id="@+id/tv_1"
                android:visibility="gone"
                android:text="Precise selection, accurate crush recommendation"
                android:textColor="@color/color_999999"
                android:layout_marginHorizontal="@dimen/dp_25"
                android:textSize="@dimen/sp_13" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:visibility="gone"
                android:layout_marginTop="@dimen/dp_15"
                android:layout_marginStart="@dimen/dp_25"
                android:layout_marginEnd="@dimen/dp_10"
                android:layout_weight="1"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                tools:listitem="@layout/item_figure"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
               />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.hjq.shape.view.ShapeTextView
        android:id="@+id/stv_next"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_25"
        android:layout_marginTop="@dimen/dp_18"
        android:layout_marginBottom="@dimen/dp_30"
        android:enabled="true"
        android:gravity="center"
        android:textStyle="bold"
        android:paddingVertical="@dimen/dp_16"
        android:text="Next"
        android:textColor="@color/color_333333"
        android:textSize="@dimen/sp_20"
        app:shape_radius="@dimen/dp_30"
        app:shape_solidGradientStartColor="@color/startGradientColor"
        app:shape_solidGradientEndColor="@color/endGradientColor"
        app:shape_solidPressedColor="@color/pressed_color_light" />
</LinearLayout>