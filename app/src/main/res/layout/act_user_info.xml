<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <com.chat.lib_common.widget.ErrorReLoadView
        android:id="@+id/errorReLoadView"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_height="0dp">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/mNestedScrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:overScrollMode="never"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">


                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/csl_bottom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_collapseMode="parallax"
                    app:layout_constraintTop_toTopOf="parent">


                    <com.youth.banner.Banner
                        android:id="@+id/banner"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintDimensionRatio="1:1.3"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <com.hjq.shape.view.ShapeView
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dp_200"
                        app:layout_constraintTop_toTopOf="parent"
                        app:shape_solidGradientEndColor="@color/transparent"
                        app:shape_solidGradientOrientation="topToBottom"
                        app:shape_solidGradientStartColor="#8f000000" />


                    <com.hjq.shape.view.ShapeView
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dp_100"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:shape_solidGradientEndColor="@color/transparent"
                        app:shape_solidGradientOrientation="bottomToTop"
                        app:shape_solidGradientStartColor="#131117" />


                    <com.hjq.shape.layout.ShapeLinearLayout
                        android:id="@+id/sll_address"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/dp_10"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingVertical="@dimen/dp_2"
                        android:paddingStart="@dimen/dp_7"
                        android:paddingEnd="@dimen/dp_4"
                        app:layout_constraintBottom_toTopOf="@+id/image_recyclerview"
                        app:layout_constraintStart_toStartOf="@id/image_recyclerview"
                        app:shape_radius="@dimen/dp_13"
                        app:shape_solidColor="#50000000">

                        <ImageView
                            android:layout_width="@dimen/dp_12"
                            android:layout_height="@dimen/dp_12"
                            android:src="@drawable/iv_location" />

                        <TextView
                            android:id="@+id/tv_address"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/dp_4"
                            android:textColor="@color/white"
                            android:textSize="@dimen/sp_10"
                            android:textStyle="bold" />

                    </com.hjq.shape.layout.ShapeLinearLayout>


                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/image_recyclerview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/dp_15"
                        android:layout_marginBottom="@dimen/dp_10"
                        android:orientation="horizontal"
                        android:overScrollMode="never"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        app:layout_constraintBottom_toBottomOf="parent"
                        tools:listitem="@layout/item_image_recycler_pager" />


                </androidx.constraintlayout.widget.ConstraintLayout>

                <com.hjq.shape.layout.ShapeLinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/sp_15"
                    android:paddingTop="@dimen/dp_5"
                    android:paddingBottom="@dimen/dp_80"
                    app:shape_solidColor="@color/appColor">

                    <com.hjq.shape.layout.ShapeLinearLayout
                        android:id="@+id/scl_crazy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="@dimen/dp_15"
                        android:paddingTop="@dimen/dp_15"
                        android:paddingEnd="@dimen/dp_10"
                        android:paddingBottom="@dimen/dp_10"
                        app:shape_radius="@dimen/dp_20"
                        android:visibility="gone"
                        app:shape_solidColor="@color/color_36343A">

                        <TextView
                            android:id="@+id/tv_crazy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawablePadding="@dimen/dp_5"
                            android:fontFamily="@font/arial_black"
                            android:text="#User name#'s crazy hole"
                            android:textColor="@color/color_999999"
                            android:textSize="@dimen/sp_15"
                            android:textStyle="bold"
                            app:drawableStartCompat="@drawable/iv_turn_tag_1" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/dp_1"
                            android:layout_marginVertical="@dimen/dp_10"
                            android:layout_marginEnd="@dimen/dp_5"
                            android:alpha="0.15"
                            android:background="@color/white" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/crazy_recycler_view"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:overScrollMode="never"
                            tools:itemCount="1"
                            tools:listitem="@layout/item_crazy_image" />


                    </com.hjq.shape.layout.ShapeLinearLayout>


                    <com.hjq.shape.layout.ShapeLinearLayout
                        android:id="@+id/scl_basic"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_20"
                        android:orientation="vertical"
                        android:paddingHorizontal="@dimen/dp_15"
                        android:paddingTop="@dimen/dp_15"
                        app:shape_radius="@dimen/dp_20"
                        app:shape_solidColor="@color/color_36343A">

                        <TextView
                            android:id="@+id/tv_basic"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawablePadding="@dimen/dp_5"
                            android:fontFamily="@font/arial_black"
                            android:text="Basic"
                            android:textColor="@color/color_999999"
                            android:textSize="@dimen/sp_15"
                            android:textStyle="bold"
                            app:drawableStartCompat="@drawable/iv_basic" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/dp_1"
                            android:layout_marginVertical="@dimen/dp_10"
                            android:alpha="0.15"
                            android:background="@color/white" />

                        <com.google.android.flexbox.FlexboxLayout
                            android:id="@+id/flexboxLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            app:alignItems="stretch"
                            app:flexDirection="row"
                            app:flexWrap="wrap"
                            app:justifyContent="flex_start">


                            <com.hjq.shape.view.ShapeTextView
                                android:id="@+id/stv_height"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="@dimen/dp_12"
                                android:layout_marginBottom="@dimen/dp_12"
                                android:gravity="center"
                                android:paddingHorizontal="@dimen/dp_15"
                                android:paddingVertical="@dimen/dp_8"
                                android:textColor="@color/white"
                                android:textSize="@dimen/sp_18"
                                app:shape_radius="@dimen/dp_10"
                                app:shape_solidColor="@color/white_20"
                                tools:text="165cm" />

                            <com.hjq.shape.view.ShapeTextView
                                android:id="@+id/stv_weight"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="@dimen/dp_12"
                                android:layout_marginBottom="@dimen/dp_12"
                                android:gravity="center"
                                android:paddingHorizontal="@dimen/dp_15"
                                android:paddingVertical="@dimen/dp_8"
                                android:textColor="@color/white"
                                android:textSize="@dimen/sp_18"
                                app:shape_radius="@dimen/dp_10"
                                app:shape_solidColor="@color/white_20"
                                tools:text="50kg" />

                            <com.hjq.shape.view.ShapeTextView
                                android:id="@+id/stv_profession"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="@dimen/dp_12"
                                android:layout_marginBottom="@dimen/dp_12"
                                android:gravity="center"
                                android:paddingHorizontal="@dimen/dp_15"
                                android:paddingVertical="@dimen/dp_8"
                                android:textColor="@color/white"
                                android:textSize="@dimen/sp_18"
                                app:shape_radius="@dimen/dp_10"
                                app:shape_solidColor="@color/white_20"
                                tools:text="Firefighter" />


                        </com.google.android.flexbox.FlexboxLayout>


                    </com.hjq.shape.layout.ShapeLinearLayout>


                    <com.hjq.shape.layout.ShapeLinearLayout
                        android:id="@+id/scl_niw"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_20"
                        android:orientation="vertical"
                        android:padding="@dimen/dp_15"
                        app:shape_radius="@dimen/dp_20"
                        app:shape_solidColor="@color/color_36343A">

                        <TextView
                            android:id="@+id/tv_niw"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawablePadding="@dimen/dp_5"
                            android:fontFamily="@font/arial_black"
                            android:text="Now I Want"
                            android:textColor="@color/color_999999"
                            android:textSize="@dimen/sp_15"
                            android:textStyle="bold"
                            app:drawableStartCompat="@drawable/iv_niw" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/dp_1"
                            android:layout_marginVertical="@dimen/dp_10"
                            android:alpha="0.15"
                            android:background="@color/white" />


                        <TextView
                            android:id="@+id/tv_socialAim"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="@dimen/sp_21"
                            android:fontFamily="@font/shrikhand_regular"
                            android:visibility="visible" />

                    </com.hjq.shape.layout.ShapeLinearLayout>


                    <com.hjq.shape.layout.ShapeLinearLayout
                        android:id="@+id/scl_about_me"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_20"
                        android:orientation="vertical"
                        android:padding="@dimen/dp_15"
                        app:shape_radius="@dimen/dp_20"
                        app:shape_solidColor="@color/color_36343A">

                        <TextView
                            android:id="@+id/tv_about_me"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawablePadding="@dimen/dp_1_5"
                            android:fontFamily="@font/arial_black"
                            android:text="About Me"
                            android:textColor="@color/color_999999"
                            android:textSize="@dimen/sp_15"
                            android:textStyle="bold"
                            app:drawableStartCompat="@drawable/iv_about" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/dp_1"
                            android:layout_marginVertical="@dimen/dp_10"
                            android:alpha="0.15"
                            android:background="@color/white" />

                        <com.hjq.shape.view.ShapeTextView
                            android:id="@+id/tv_introductions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="@dimen/sp_18"
                            tools:text="Hello everyone! My name is [Your Name].
I am currently [Your Age] years old and I have a wide
 range of interests. I am passionate about reading,
 which allows me to explore different worlds and gain
diverse knowledge. I also enjoy music and often immersemyself in the beautiful melodies to relax" />

                    </com.hjq.shape.layout.ShapeLinearLayout>


                    <com.hjq.shape.layout.ShapeLinearLayout
                        android:id="@+id/scl_interests"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_20"
                        android:orientation="vertical"
                        android:padding="@dimen/dp_15"
                        app:shape_radius="@dimen/dp_20"
                        app:shape_solidColor="@color/color_36343A">

                        <TextView
                            android:id="@+id/tv_interests"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawablePadding="@dimen/dp_5"
                            android:fontFamily="@font/arial_black"
                            android:text="Interests"
                            android:textColor="@color/color_999999"
                            android:textSize="@dimen/sp_15"
                            android:textStyle="bold"
                            app:drawableStartCompat="@drawable/iv_interests" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/dp_1"
                            android:layout_marginVertical="@dimen/dp_10"
                            android:alpha="0.15"
                            android:background="@color/white" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:overScrollMode="never" />


                    </com.hjq.shape.layout.ShapeLinearLayout>

                    <com.hjq.shape.layout.ShapeLinearLayout
                        android:id="@+id/scl_turn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_20"
                        android:orientation="vertical"
                        android:paddingVertical="@dimen/dp_15"
                        android:paddingStart="@dimen/dp_15"
                        app:shape_radius="@dimen/dp_20"
                        android:visibility="gone"
                        app:shape_solidColor="@color/color_36343A">

                        <TextView
                            android:id="@+id/tv_turn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawablePadding="@dimen/dp_5"
                            android:fontFamily="@font/arial_black"
                            android:text="Turn ons"
                            android:textColor="@color/color_999999"
                            android:textSize="@dimen/sp_15"
                            android:textStyle="bold"
                            app:drawableStartCompat="@drawable/iv_info_turn" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/dp_1"
                            android:layout_marginVertical="@dimen/dp_10"
                            android:layout_marginEnd="@dimen/dp_15"
                            android:alpha="0.15"
                            android:background="@color/white" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/turns_ons_recycler_view"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:overScrollMode="never"
                            tools:itemCount="1"
                            tools:listitem="@layout/item_turns_ons" />


                    </com.hjq.shape.layout.ShapeLinearLayout>
                </com.hjq.shape.layout.ShapeLinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>


        <com.hjq.shape.view.ShapeView
            android:id="@+id/sv_cover"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_200"
            app:layout_constraintBottom_toBottomOf="parent"
            app:shape_solidGradientEndColor="@color/transparent"
            app:shape_solidGradientOrientation="bottomToTop"
            app:shape_solidGradientStartColor="#131117" />


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/flash_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_10"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:id="@+id/iv_dislike"
                android:layout_width="@dimen/dp_56"
                android:layout_height="@dimen/dp_56"
                android:layout_marginEnd="@dimen/dp_45"
                android:src="@drawable/iv_info_dislike"
                app:layout_constraintBottom_toBottomOf="@+id/iv_flash_chat"
                app:layout_constraintEnd_toStartOf="@+id/iv_flash_chat"
                app:layout_constraintTop_toTopOf="@+id/iv_flash_chat" />

            <ImageView
                android:id="@+id/iv_flash_chat"
                android:layout_width="@dimen/dp_56"
                android:layout_height="@dimen/dp_56"
                android:layout_marginBottom="@dimen/dp_15"
                android:src="@drawable/iv_flash_chat"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <ImageView
                android:id="@+id/iv_like"
                android:layout_width="@dimen/dp_56"
                android:layout_height="@dimen/dp_56"
                android:layout_marginStart="@dimen/dp_45"
                android:src="@drawable/iv_info_like"
                app:layout_constraintBottom_toBottomOf="@+id/iv_flash_chat"
                app:layout_constraintStart_toEndOf="@+id/iv_flash_chat"
                app:layout_constraintTop_toTopOf="@+id/iv_flash_chat" />
        </androidx.constraintlayout.widget.ConstraintLayout>


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/ll_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">


            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dp_15"
                android:ellipsize="middle"
                android:fontFamily="@font/arial_black"
                android:gravity="center"
                android:maxEms="5"
                android:singleLine="true"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_24"
                android:textStyle="bold"
                app:layout_constrainedWidth="true"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="Lacus·30" />


            <com.hjq.shape.layout.ShapeLinearLayout
                android:id="@+id/sll_online"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dp_8"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingVertical="@dimen/dp_2"
                android:paddingStart="@dimen/dp_7"
                android:paddingEnd="@dimen/dp_4"
                app:layout_constraintBottom_toBottomOf="@+id/tv_title"
                app:layout_constraintStart_toEndOf="@+id/tv_title"
                app:layout_constraintTop_toTopOf="@+id/tv_title"
                app:shape_radius="@dimen/dp_13"
                app:shape_solidColor="#cf3BD800">

                <com.hjq.shape.view.ShapeView
                    android:layout_width="@dimen/dp_6"
                    android:layout_height="@dimen/dp_6"
                    app:shape_radius="@dimen/dp_6"
                    app:shape_solidColor="@color/white" />

                <TextView
                    android:id="@+id/tv_online"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp_4"
                    android:text="Online"
                    android:textColor="@color/white"
                    android:textSize="@dimen/sp_10"
                    android:textStyle="bold" />

            </com.hjq.shape.layout.ShapeLinearLayout>


            <ImageView
                android:id="@+id/iv_close"
                android:layout_width="@dimen/dp_40"
                android:layout_height="@dimen/dp_40"
                android:padding="@dimen/dp_8"
                android:src="@drawable/iv_info_close"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/iv_more"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/iv_more"
                android:layout_width="@dimen/dp_40"
                android:layout_height="@dimen/dp_40"
                android:layout_marginEnd="@dimen/dp_15"
                android:padding="@dimen/dp_8"
                android:src="@drawable/iv_more_w"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />


        </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.chat.lib_common.widget.ErrorReLoadView>


</androidx.constraintlayout.widget.ConstraintLayout>
