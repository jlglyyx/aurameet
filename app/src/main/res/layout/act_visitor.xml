<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <com.chat.jolt.widget.MToolBar
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        android:id="@+id/appToolBar"
        app:title="Visitor"
        />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/mSwipeRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <com.chat.lib_common.widget.ErrorReLoadView
            android:id="@+id/errorReLoadView"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginEnd="@dimen/dp_5"
                android:overScrollMode="never"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:itemCount="5"
                tools:listitem="@layout/item_visitor" />


            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent">


                <com.hjq.shape.view.ShapeView
                    android:id="@+id/sv_cover"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_100"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:shape_solidGradientEndColor="@color/transparent"
                    app:shape_solidGradientOrientation="bottomToTop"
                    app:shape_solidGradientStartColor="@color/appColor" />

                <LinearLayout
                    android:id="@+id/scl_open_vip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/dp_45"
                    android:layout_marginBottom="@dimen/dp_18"
                    android:gravity="center"
                    android:background="@drawable/iv_b_open_vip_bg"
                    android:orientation="horizontal"
                    android:paddingVertical="@dimen/dp_14"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                   >


                    <ImageView
                        android:layout_width="@dimen/dp_28"
                        android:layout_height="@dimen/dp_28"
                        android:src="@drawable/iv_open_like_vip" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/dp_5"
                        android:text="Unlock All My Visitor"
                        android:textColor="@color/color_563500"
                        android:textSize="@dimen/sp_14"
                        android:layout_marginTop="@dimen/dp_2"
                        android:textStyle="bold" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.chat.lib_common.widget.ErrorReLoadView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>