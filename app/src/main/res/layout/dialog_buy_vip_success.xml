<?xml version="1.0" encoding="utf-8"?>
<com.hjq.shape.layout.ShapeConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:gravity="center"
    app:shape_radiusInTopLeft="@dimen/dp_20"
    app:shape_radiusInTopRight="@dimen/dp_20"
    app:shape_solidColor="@color/color_222222"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/iv_close"
        android:src="@drawable/iv_close_filter"
        android:layout_width="@dimen/dp_35"
        android:layout_gravity="end"
        android:padding="@dimen/dp_5"
        android:paddingHorizontal="@dimen/dp_5"
        android:layout_marginHorizontal="@dimen/dp_10"
        android:layout_height="@dimen/dp_35"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="@dimen/dp_15" />


    <ImageView
        android:layout_marginHorizontal="@dimen/dp_60"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/arial_black"
        android:textStyle="bold"
        android:src="@drawable/iv_congratulations_text"
        android:id="@+id/tv_title"
        android:layout_marginTop="@dimen/dp_25"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:textSize="@dimen/sp_28"
        android:textColor="@color/color_151515"
        />


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_10"
        android:layout_marginTop="@dimen/dp_20"
        android:overScrollMode="never"
        tools:itemCount="1"
        app:layout_constraintTop_toBottomOf="@+id/tv_title"
        tools:listitem="@layout/item_vip_success" />


    <com.hjq.shape.view.ShapeTextView
        android:id="@+id/stv_next"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_20"
        android:layout_marginTop="@dimen/dp_5"
        android:layout_marginBottom="@dimen/dp_25"
        app:layout_constraintBottom_toBottomOf="parent"
        android:gravity="center"
        android:paddingVertical="@dimen/dp_12"
        android:text="Got it！"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:textSize="@dimen/sp_18"
        app:shape_radius="@dimen/dp_29"
        app:layout_constraintTop_toBottomOf="@id/recyclerView"
        app:shape_solidColor="@color/color_button"
        app:shape_solidPressedColor="@color/pressed_color_light" />



</com.hjq.shape.layout.ShapeConstraintLayout>
