<?xml version="1.0" encoding="utf-8"?>
<com.hjq.shape.layout.ShapeLinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    >

    <com.hjq.shape.layout.ShapeLinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="@dimen/dp_10"
        android:layout_marginHorizontal="@dimen/dp_10"
        android:orientation="vertical">

        <com.hjq.shape.layout.ShapeLinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:shape_radius="@dimen/dp_10"
            app:shape_solidColor="@color/color_222222">


            <com.hjq.shape.view.ShapeTextView
                android:id="@+id/tv_block"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="@dimen/dp_20"
                android:text="Block"
                app:shape_solidPressedColor="@color/pressed_color_dark"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_16" />

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_0_5"
                android:layout_marginHorizontal="@dimen/dp_20"
                android:background="@color/color_20000000" />
            <com.hjq.shape.view.ShapeTextView
                android:id="@+id/tv_retort"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="@dimen/dp_20"
                android:text="Report"
                android:textStyle="bold"
                app:shape_solidPressedColor="@color/pressed_color_dark"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_16" />



        </com.hjq.shape.layout.ShapeLinearLayout>

        <com.hjq.shape.view.ShapeTextView
            android:id="@+id/tv_cancel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_10"
            android:gravity="center"
            android:padding="@dimen/dp_17"
            android:text="Cancel"
            app:shape_solidPressedColor="@color/pressed_color_dark"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:textSize="@dimen/sp_16"
            app:shape_radius="@dimen/dp_10"
            app:shape_solidColor="@color/color_222222" />

    </com.hjq.shape.layout.ShapeLinearLayout>

</com.hjq.shape.layout.ShapeLinearLayout>