<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">
<com.hjq.shape.layout.ShapeConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:layout_constraintBottom_toBottomOf="parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:shape_radiusInTopLeft="@dimen/dp_20"
    app:shape_radiusInTopRight="@dimen/dp_20"
    android:orientation="vertical"
    android:gravity="center"
    android:clickable="true"
    android:focusable="true"
    android:id="@+id/scl_container"
    android:paddingHorizontal="@dimen/dp_15"
    app:shape_solidColor="@color/color_222222">



    <ImageView
        android:layout_width="@dimen/dp_32"
        android:layout_height="@dimen/dp_32"
        android:id="@+id/iv_close"
        android:padding="@dimen/dp_2"
        android:layout_marginTop="@dimen/dp_25"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:src="@drawable/iv_close_buy_right" />
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/arial_black"
        android:text="About Me"
        android:layout_marginTop="@dimen/dp_25"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:textColor="@color/white"
        android:textSize="@dimen/sp_20"
        android:textStyle="bold" />


    <com.hjq.shape.view.ShapeTextView
        android:id="@+id/tv_save"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/dp_10"
        android:gravity="center"
        android:paddingHorizontal="@dimen/dp_10"
        android:paddingVertical="@dimen/dp_2"
        android:textColor="@color/white"
        android:text="Save"
        android:enabled="false"
        app:shape_solidDisabledColor="@color/color_C5C5C5"
        android:textSize="@dimen/sp_14"
        app:shape_radius="@dimen/dp_12"
        app:shape_solidPressedColor="@color/pressed_color_dark"
        app:shape_solidColor="@color/color_button"
        app:layout_constraintTop_toTopOf="@+id/tv_title"
        app:layout_constraintBottom_toBottomOf="@id/tv_title"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.hjq.shape.view.ShapeEditText
        android:id="@+id/set_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_20"
        android:background="@null"
        android:gravity="top"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="@dimen/dp_25"
        android:hint="fill in…"
        android:maxLength="200"
        android:minLines="6"
        android:paddingHorizontal="@dimen/dp_12"
        android:paddingVertical="@dimen/dp_15"
        android:textColor="@color/white"
        android:textColorHint="@color/color_999999"
        android:textSize="@dimen/sp_14"
        android:textStyle="bold"
        app:shape_radius="@dimen/dp_15"
        app:layout_constraintTop_toBottomOf="@+id/tv_title"
        app:shape_solidColor="@color/white_20" />


</com.hjq.shape.layout.ShapeConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>