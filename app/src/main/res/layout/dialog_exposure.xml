<?xml version="1.0" encoding="utf-8"?>
<com.hjq.shape.layout.ShapeLinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    app:shape_radiusInTopLeft="@dimen/dp_20"
    app:shape_radiusInTopRight="@dimen/dp_20"
    app:shape_strokeSize="@dimen/dp_1"
    app:shape_strokeColor="@color/color_FDFFD2"
   app:shape_solidColor="@color/color_1B1B1D">


    <ImageView
        android:layout_gravity="end"
        android:layout_width="@dimen/dp_40"
        android:layout_height="@dimen/dp_40"
        android:id="@+id/iv_close"
        android:layout_marginTop="@dimen/dp_15"
        android:src="@drawable/iv_exposure_close"
        />

    <ImageView
        android:layout_marginTop="@dimen/dp_5"
        android:layout_width="@dimen/dp_170"
        android:layout_height="@dimen/dp_170"
        android:src="@drawable/iv_exposure"
        />


    <com.hjq.shape.view.ShapeTextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_20"
        android:gravity="center"
        android:layout_marginHorizontal="@dimen/dp_15"
        android:text="Increase exposure"
        android:textColor="@color/white"
        app:shape_textStartColor="@color/startGradientColor"
        app:shape_textCenterColor="@color/endGradientColor"
        android:textSize="@dimen/sp_24"
        android:textStyle="bold|italic" />

    <TextView
        android:id="@+id/tv_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_12"
        android:gravity="center"
        android:layout_marginHorizontal="@dimen/dp_15"
        android:lineSpacingExtra="@dimen/dp_3"
        android:text="Next 30 mins, top priority exposure!"
        android:textColor="@color/color_999999"
        android:textSize="@dimen/sp_18" />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_30"
        android:layout_marginHorizontal="@dimen/dp_15"
        android:layout_marginBottom="@dimen/dp_20"
        android:orientation="horizontal">


        <com.hjq.shape.view.ShapeTextView
            android:id="@+id/tv_commit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:enabled="true"
            android:gravity="center"
            android:paddingVertical="@dimen/dp_17"
            android:text="Find Friends"
            android:textColor="@color/firstTextColor"
            android:textSize="@dimen/sp_16"
            android:textStyle="bold"
            app:shape_radius="@dimen/dp_30"
            app:shape_solidGradientStartColor="@color/startGradientColor"
            app:shape_solidGradientEndColor="@color/endGradientColor"
            app:shape_solidPressedColor="@color/pressed_color_dark" />

    </LinearLayout>

</com.hjq.shape.layout.ShapeLinearLayout>