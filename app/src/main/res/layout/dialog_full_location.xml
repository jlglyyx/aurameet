<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_131117"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    app:shape_radiusInTopLeft="@dimen/dp_20"
    app:shape_radiusInTopRight="@dimen/dp_20">


    <ImageView
        android:id="@+id/iv_image"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/stv_confirm"
        app:layout_constraintVertical_bias="0.35"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:src="@drawable/iv_full_location" />

    <ImageView
        app:layout_constraintTop_toBottomOf="@+id/iv_image"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_46"
        android:src="@drawable/iv_full_location_text" />

    <com.hjq.shape.layout.ShapeLinearLayout
        android:id="@+id/stv_confirm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_25"
        android:layout_marginTop="@dimen/dp_60"
        android:layout_marginBottom="@dimen/dp_20"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingVertical="@dimen/dp_17"
        app:shape_radius="@dimen/dp_29"
        app:layout_constraintBottom_toTopOf="@+id/tv_cancel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:shape_solidColor="@color/color_EAA82B"
        app:shape_solidPressedColor="@color/pressed_color_light">

        <ImageView
            android:layout_width="@dimen/dp_17"
            android:layout_height="@dimen/dp_20"
            android:src="@drawable/iv_location" />

        <com.hjq.shape.view.ShapeTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_5"
            android:gravity="center"
            android:text="Turn on"
            android:textColor="@color/white"
            android:textSize="@dimen/sp_18" />

    </com.hjq.shape.layout.ShapeLinearLayout>


    <TextView
        android:id="@+id/tv_cancel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dp_35"
        android:text="Maybe Later"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:textColor="@color/white"
        android:textSize="@dimen/sp_14" />


</androidx.constraintlayout.widget.ConstraintLayout>