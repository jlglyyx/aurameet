<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">


    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:overScrollMode="never"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/appToolBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="@dimen/dp_35"
            android:layout_height="@dimen/dp_35"
            android:padding="@dimen/dp_5"
            android:layout_marginStart="@dimen/dp_8"
            android:src="@drawable/iv_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />


        <TextView
            android:id="@+id/tv_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="middle"
            android:gravity="center"
            android:maxEms="8"
            android:singleLine="true"
            android:text="1/3"
            android:textColor="@color/white"
            android:textSize="@dimen/sp_18"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <ImageView
            android:id="@+id/iv_right"
            android:layout_width="@dimen/dp_35"
            android:layout_height="@dimen/dp_35"
            android:padding="@dimen/dp_5"
            android:layout_marginEnd="@dimen/dp_8"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>




    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_flash_chat"
        android:layout_width="match_parent"
        android:layout_height="match_parent">



        <com.hjq.shape.view.ShapeTextView
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_150"
            app:layout_constraintBottom_toBottomOf="parent"
            app:shape_solidGradientEndColor="@color/transparent"
            app:shape_solidGradientOrientation="bottomToTop"
            app:shape_solidGradientStartColor="@color/black_80"/>

        <TextView
            android:id="@+id/tv_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_20"
            android:layout_marginEnd="@dimen/dp_10"
            android:ellipsize="end"
            android:fontFamily="@font/arial_black"
            android:singleLine="true"
            android:textColor="@color/white"
            android:textSize="@dimen/sp_28"
            android:layout_marginBottom="@dimen/dp_10"
            app:layout_constraintBottom_toTopOf="@+id/sll_online"
            app:layout_constraintEnd_toStartOf="@+id/iv_crazy_flush_chat"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:id="@+id/iv_crazy_flush_chat"
            android:layout_width="@dimen/dp_60"
            android:layout_height="@dimen/dp_60"
            android:layout_marginEnd="@dimen/dp_20"
            android:src="@drawable/iv_crazy_flush_chat"
            app:layout_constraintBottom_toBottomOf="@id/sll_online"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_name" />


        <com.hjq.shape.layout.ShapeLinearLayout
            android:id="@+id/sll_online"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/dp_4"
            android:gravity="center"
            android:layout_marginBottom="@dimen/dp_15"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/dp_8"
            android:paddingVertical="@dimen/dp_4"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@+id/tv_name"
            app:shape_radius="@dimen/dp_13"
            app:shape_solidColor="#cf3BD800">

            <com.hjq.shape.view.ShapeView
                android:layout_width="@dimen/dp_10"
                android:layout_height="@dimen/dp_10"
                app:shape_radius="@dimen/dp_6"
                app:shape_solidColor="@color/white" />

            <TextView
                android:id="@+id/tv_online"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dp_6"
                android:text="Online"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_12" />

        </com.hjq.shape.layout.ShapeLinearLayout>

        <com.hjq.shape.layout.ShapeLinearLayout
            android:id="@+id/sll_address"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_10"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/dp_8"
            android:paddingVertical="@dimen/dp_4"
            app:layout_constraintStart_toEndOf="@+id/sll_online"
            app:layout_constraintTop_toTopOf="@+id/sll_online"
            app:shape_radius="@dimen/dp_13"
            app:shape_solidColor="@color/color_BB46EB">


            <ImageView
                android:layout_width="@dimen/dp_10"
                android:layout_height="@dimen/dp_12"
                android:src="@drawable/iv_location" />

            <TextView
                android:id="@+id/tv_address"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dp_4"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_12" />

        </com.hjq.shape.layout.ShapeLinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.constraintlayout.widget.ConstraintLayout>