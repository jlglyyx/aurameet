<?xml version="1.0" encoding="utf-8"?>
<com.hjq.shape.layout.ShapeConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:gravity="center"
    android:orientation="vertical"
    app:shape_radiusInTopLeft="@dimen/dp_22"
    app:shape_radiusInTopRight="@dimen/dp_22"
    app:shape_solidGradientEndColor="@color/appColor"
    app:shape_solidGradientOrientation="topToBottom"
    app:shape_solidGradientStartColor="@color/appColor">




    <ImageView
        android:id="@+id/iv_image"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scaleType="fitXY"
        android:src="@drawable/iv_retain_bg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/iv_retain_0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:src="@drawable/iv_retain_0"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="@dimen/dp_10"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="@+id/iv_image" />


    <com.hjq.shape.layout.ShapeLinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/sll_container"
        app:shape_solidColor="@color/color_36343A"
        android:layout_marginHorizontal="@dimen/dp_15"
        app:shape_radius="@dimen/dp_15"
        android:paddingVertical="@dimen/dp_15"
        android:layout_marginTop="@dimen/dp_10"
        app:layout_constraintTop_toBottomOf="@+id/iv_image"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/iv_retain_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:src="@drawable/iv_retain_1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/iv_image" />

        <androidx.recyclerview.widget.RecyclerView
            android:layout_width="match_parent"
            android:id="@+id/recyclerView"
            tools:listitem="@layout/item_retain_notice"
            app:layout_constraintTop_toBottomOf="@+id/iv_retain_1"
            android:layout_height="wrap_content"/>
    </com.hjq.shape.layout.ShapeLinearLayout>




    <com.hjq.shape.view.ShapeTextView
        android:id="@+id/stv_confirm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_15"
        android:layout_marginTop="@dimen/dp_20"
        android:layout_marginBottom="@dimen/dp_20"
        android:gravity="center"
        android:paddingVertical="@dimen/dp_14"
        android:text="Continue"
        android:textColor="@color/white"
        android:textSize="@dimen/sp_16"
        android:textStyle="bold"
        app:shape_radius="@dimen/dp_25"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/sll_container"
        app:shape_solidColor="@color/color_EAA82B"
        app:shape_solidPressedColor="@color/pressed_color_light" />


    <ImageView
        android:id="@+id/iv_close"
        android:layout_width="@dimen/dp_40"
        android:layout_height="@dimen/dp_40"
        android:layout_gravity="end"
        android:layout_marginTop="@dimen/dp_10"
        android:layout_marginEnd="@dimen/dp_10"
        android:padding="@dimen/dp_8"
        app:layout_constraintTop_toTopOf="parent"
        android:src="@drawable/iv_close_filter"
        app:layout_constraintEnd_toEndOf="parent" />

</com.hjq.shape.layout.ShapeConstraintLayout>