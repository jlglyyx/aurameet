<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_height="wrap_content">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:src="@drawable/iv_update_bg"
            android:id="@+id/iv_bg"
            android:scaleType="fitXY"
            app:layout_constraintTop_toTopOf="parent" />
        <ImageView
            app:layout_constraintEnd_toEndOf="@+id/iv_bg"
            android:layout_width="@dimen/dp_30"
            android:layout_height="@dimen/dp_30"
            android:id="@+id/iv_close"
            android:padding="@dimen/dp_2"
            android:src="@drawable/iv_update_close"
            app:layout_constraintVertical_bias="0.22"
            android:layout_marginEnd="@dimen/dp_9"
            android:layout_marginTop="@dimen/dp_12"
            app:layout_constraintBottom_toBottomOf="@+id/iv_bg"
            app:layout_constraintTop_toTopOf="@+id/iv_bg" />

    </androidx.constraintlayout.widget.ConstraintLayout>


    <com.hjq.shape.layout.ShapeLinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:shape_solidColor="@color/color_FEF3FF"
        app:shape_radiusInBottomRight="@dimen/dp_20"
        app:shape_radiusInBottomLeft="@dimen/dp_20"
        android:paddingBottom="@dimen/dp_20"
        android:layout_marginTop="-30dp"
        android:paddingHorizontal="@dimen/dp_25"
        android:orientation="vertical">


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="@dimen/sp_16"
        android:textColor="@color/color_151515"
        android:id="@+id/tv_title"
        android:text="Discover a new version"
        android:textStyle="bold"
       />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="@dimen/sp_14"
        android:lineSpacingExtra="@dimen/dp_3"
        android:textColor="@color/color_999999"
        android:id="@+id/tv_content"
        android:layout_marginTop="@dimen/dp_10"
        tools:text="After logging out, no historical data will be deleted, and you can still use this account the next time you log in After logging out, no historical data will be deleted, and you can still use this account the next time you log inAfter logging out, no historical data will be deleted, and you can still use this account the next time you log in"
       />


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_20"
            android:orientation="horizontal">


            <com.hjq.shape.view.ShapeTextView
                android:id="@+id/tv_cancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/dp_20"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingVertical="@dimen/dp_14"
                android:text="Cancel"
                android:textColor="@color/color_666666"
                android:textSize="@dimen/sp_16"
                app:shape_radius="@dimen/dp_25"
                app:shape_strokeColor="@color/color_666666"
                app:shape_strokeSize="@dimen/dp_2" />

            <com.hjq.shape.view.ShapeTextView
                android:id="@+id/tv_commit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:enabled="true"
                android:gravity="center"
                android:paddingVertical="@dimen/dp_14"
                android:text="Update"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_16"
                app:shape_radius="@dimen/dp_25"
                app:shape_solidColor="@color/color_button"
                app:shape_solidPressedColor="@color/pressed_color_dark" />

        </LinearLayout>

    </com.hjq.shape.layout.ShapeLinearLayout>

</LinearLayout>