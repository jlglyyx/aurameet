<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cl_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <FrameLayout
        android:id="@+id/fl_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="@dimen/dp_15"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.youth.banner.Banner
            android:id="@+id/banner"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <com.hjq.shape.view.ShapeView
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_220"
            android:layout_gravity="bottom"
            app:shape_radiusInBottomLeft="@dimen/dp_15"
            app:shape_radiusInBottomRight="@dimen/dp_15"
            app:shape_solidGradientCenterColor="@color/color_1F1F1F"
            app:shape_solidGradientEndColor="@color/color_1F1F1F"
            app:shape_solidGradientOrientation="topToBottom"
            app:shape_solidGradientStartColor="@color/transparent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:id="@+id/ll_indicator"
            android:layout_marginHorizontal="@dimen/dp_20"
            android:orientation="horizontal">

            <com.youth.banner.indicator.RectangleIndicator
                android:id="@+id/mIndicator"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_4" />
        </LinearLayout>

    </FrameLayout>


    <View
        android:id="@+id/view"
        android:layout_width="@dimen/dp_1"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <View
        android:id="@+id/view_left"
        android:layout_width="@dimen/dp_0"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/fl_container"
        app:layout_constraintEnd_toStartOf="@+id/view"
        app:layout_constraintStart_toStartOf="@+id/fl_container"
        app:layout_constraintTop_toTopOf="@+id/fl_container" />


    <View
        android:id="@+id/view_right"
        android:layout_width="@dimen/dp_0"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/fl_container"
        app:layout_constraintEnd_toEndOf="@+id/fl_container"
        app:layout_constraintStart_toEndOf="@+id/view"
        app:layout_constraintTop_toTopOf="@+id/fl_container" />


    <ImageView
        android:id="@+id/iv_like_status"
        android:layout_width="@dimen/dp_100"
        android:layout_height="@dimen/dp_100"
        android:visibility="gone"
        android:src="@drawable/iv_like_status"
        app:layout_constraintEnd_toEndOf="@+id/fl_container"
        app:layout_constraintBottom_toBottomOf="@+id/fl_container"
        app:layout_constraintStart_toStartOf="@id/fl_container"
        app:layout_constraintTop_toTopOf="@id/fl_container" />

    <ImageView
        android:id="@+id/iv_dislike_status"
        android:layout_width="@dimen/dp_100"
        android:layout_height="@dimen/dp_100"
        android:visibility="gone"
        android:src="@drawable/iv_dislike_status"
        app:layout_constraintEnd_toEndOf="@+id/fl_container"
        app:layout_constraintBottom_toBottomOf="@+id/fl_container"
        app:layout_constraintStart_toStartOf="@id/fl_container"
        app:layout_constraintTop_toTopOf="@id/fl_container" />


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_info"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="@dimen/dp_15"
        app:layout_constraintBottom_toBottomOf="@+id/fl_container"
        app:layout_constraintEnd_toEndOf="@+id/fl_container"
        app:layout_constraintStart_toStartOf="@+id/fl_container">


        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_avatar"
            android:layout_width="@dimen/dp_58"
            android:layout_height="@dimen/dp_58"
            android:padding="@dimen/dp_2"
            android:scaleType="centerCrop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearance="@style/circleStyle"
            app:strokeColor="@color/white"
            app:strokeWidth="@dimen/dp_2" />

        <TextView
            android:id="@+id/tv_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_8"
            android:layout_marginEnd="@dimen/dp_10"
            android:ellipsize="end"
            android:fontFamily="@font/arial_black"
            android:singleLine="true"
            android:textColor="@color/white"
            android:textSize="@dimen/sp_22"
            app:layout_constraintEnd_toStartOf="@+id/iv_to_info"
            app:layout_constraintStart_toEndOf="@+id/iv_avatar"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/iv_to_info"
            android:layout_width="@dimen/dp_28"
            android:layout_height="@dimen/dp_28"
            android:src="@drawable/iv_to_info"
            app:layout_constraintBottom_toBottomOf="@id/iv_avatar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/iv_avatar" />


        <com.hjq.shape.layout.ShapeLinearLayout
            android:id="@+id/sll_online"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_3"
            android:layout_marginEnd="@dimen/dp_4"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/dp_8"
            android:paddingVertical="@dimen/dp_7"
            app:layout_constraintStart_toStartOf="@+id/tv_name"
            app:layout_constraintTop_toBottomOf="@+id/tv_name"
            app:shape_radius="@dimen/dp_8"
            app:shape_solidColor="@color/color_7FEA04">

            <TextView
                android:id="@+id/tv_online"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:text="Online"
                android:textColor="@color/firstTextColor"
                android:textSize="@dimen/sp_12" />

        </com.hjq.shape.layout.ShapeLinearLayout>

        <com.hjq.shape.layout.ShapeLinearLayout
            android:id="@+id/sll_address"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_8"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/dp_8"
            android:paddingVertical="@dimen/dp_7"
            app:layout_constraintStart_toEndOf="@+id/sll_online"
            app:layout_constraintTop_toTopOf="@+id/sll_online"
            app:shape_radius="@dimen/dp_8"
            app:shape_solidColor="@color/color_FF8032">

            <ImageView
                android:layout_width="@dimen/dp_12"
                android:layout_height="@dimen/dp_12"
                android:src="@drawable/iv_location" />

            <TextView
                android:id="@+id/tv_address"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dp_4"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="@dimen/sp_12" />

        </com.hjq.shape.layout.ShapeLinearLayout>


        <com.hjq.shape.layout.ShapeConstraintLayout
            android:id="@+id/sll_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_15"
            android:gravity="center_vertical"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/iv_avatar">


            <TextView
                android:id="@+id/tv_0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.5"
                android:text="Now I Want："
                android:textColor="@color/white"
                android:textSize="@dimen/sp_14"
                android:textStyle="bold"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"

                />

            <TextView
                android:id="@+id/tv_content"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_20"
                android:textStyle="bold"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/tv_0"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.flexbox.FlexboxLayout
                android:id="@+id/hobby_flexbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:flexWrap="wrap"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.hjq.shape.view.ShapeTextView
                android:id="@+id/stv_turn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/iv_turn_tag"
                android:drawablePadding="@dimen/dp_4"
                android:paddingHorizontal="@dimen/dp_8"
                android:paddingVertical="@dimen/dp_4"
                android:text="0 Turn-ons"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_14"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:shape_radius="@dimen/dp_6"
               />


        </com.hjq.shape.layout.ShapeConstraintLayout>


        <ImageView
            android:id="@+id/iv_dislike"
            android:layout_width="@dimen/dp_56"
            android:layout_height="@dimen/dp_56"
            android:layout_marginTop="@dimen/dp_20"
            android:src="@drawable/iv_dislike"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/sll_container" />

        <ImageView
            android:id="@+id/iv_flash_chat"
            android:layout_width="@dimen/dp_56"
            android:layout_height="@dimen/dp_56"
            android:layout_marginStart="@dimen/dp_15"
            android:src="@drawable/iv_flash_chat"
            app:layout_constraintStart_toEndOf="@+id/iv_dislike"
            app:layout_constraintTop_toTopOf="@+id/iv_dislike" />

        <ImageView
            android:id="@+id/iv_like"
            android:layout_width="@dimen/dp_144"
            android:layout_height="@dimen/dp_56"
            android:src="@drawable/iv_like"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/iv_dislike" />
    </androidx.constraintlayout.widget.ConstraintLayout>


    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_notice_pic_change"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="@dimen/dp_15"
        android:scaleType="fitXY"
        android:src="@drawable/iv_notice_pic_change"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/fl_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/fl_container"
        app:shapeAppearance="@style/CardCorners" />


</androidx.constraintlayout.widget.ConstraintLayout>

