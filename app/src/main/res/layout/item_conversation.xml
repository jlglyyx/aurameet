<?xml version="1.0" encoding="utf-8"?>
<com.chat.lib_common.widget.SwipeMenuLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeMenuLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/dp_10"
    android:clickable="true">


    <com.hjq.shape.layout.ShapeLinearLayout
        android:id="@+id/ll_pin"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        app:shape_radius="@dimen/dp_12"
        app:shape_solidColor="@color/color_999999"
        android:paddingHorizontal="@dimen/dp_25">

        <ImageView
            android:id="@+id/iv_pin"
            android:layout_width="@dimen/dp_30"
            android:layout_height="@dimen/dp_30"
            android:src="@drawable/iv_pin" />


    </com.hjq.shape.layout.ShapeLinearLayout>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/dp_10"
        android:paddingVertical="@dimen/dp_10">


        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_avatar"
            android:layout_width="@dimen/dp_52"
            android:layout_height="@dimen/dp_52"
            android:scaleType="centerCrop"
            android:src="@drawable/iv_conversation_notice"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/circleStyle"
            app:strokeColor="@color/transparent" />

        <com.hjq.shape.view.ShapeTextView
            android:id="@+id/stv_aline"
            android:layout_width="@dimen/dp_13"
            android:layout_height="@dimen/dp_13"
            android:gravity="center"
            android:textSize="@dimen/sp_12"
            app:layout_constraintBottom_toBottomOf="@+id/iv_avatar"
            app:layout_constraintEnd_toEndOf="@+id/iv_avatar"
            app:shape_radius="@dimen/dp_30"
            app:shape_solidColor="@color/color_7FEA04"
           />


        <LinearLayout
            android:id="@+id/ll_container"
            android:layout_width="0dp"
            android:layout_marginEnd="@dimen/dp_10"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_12"
            android:layout_marginTop="@dimen/dp_5"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintEnd_toStartOf="@+id/tv_update_time"
            app:layout_constraintStart_toEndOf="@+id/iv_avatar"
            app:layout_constraintTop_toTopOf="@+id/iv_avatar">


            <TextView
                android:id="@+id/tv_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxEms="6"
                android:singleLine="true"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_17"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@+id/tv_update_time"
                app:layout_constraintStart_toEndOf="@+id/iv_avatar"
                app:layout_constraintTop_toTopOf="@+id/iv_avatar" />

            <ImageView
                android:id="@+id/iv_flash_tag"
                android:layout_width="@dimen/dp_18"
                android:layout_height="@dimen/dp_18"
                android:layout_marginStart="@dimen/dp_6"
                android:src="@drawable/iv_flash_tag"
                android:visibility="gone" />
            <ImageView
                android:id="@+id/iv_love"
                android:layout_width="@dimen/dp_34"
                android:layout_height="@dimen/dp_18"
                android:layout_marginStart="@dimen/dp_6"
                android:src="@drawable/iv_love"
                android:visibility="gone" />

        </LinearLayout>


        <TextView
            android:id="@+id/tv_update_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_2"
            android:text="2026.06.12"
            android:textColor="@color/white_70"
            android:textSize="@dimen/sp_13"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/ll_container" />

        <ImageView
            android:id="@+id/iv_em"
            android:layout_width="@dimen/dp_18"
            android:layout_height="@dimen/dp_18"
            android:src="@drawable/iv_em"
            android:layout_marginEnd="@dimen/dp_6"
            app:layout_constraintBottom_toBottomOf="@+id/iv_avatar"
            app:layout_constraintStart_toStartOf="@+id/ll_container"
            app:layout_constraintTop_toBottomOf="@+id/ll_container"
            app:layout_constraintEnd_toStartOf="@+id/tv_message"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/dp_10"
            android:ellipsize="end"
            android:singleLine="true"
            android:textColor="@color/white_70"
            android:textSize="@dimen/sp_12"
            app:layout_constraintBottom_toBottomOf="@+id/iv_avatar"
            app:layout_constraintEnd_toStartOf="@+id/iv_pin_tag"
            app:layout_constraintStart_toEndOf="@+id/iv_em"
            app:layout_constraintTop_toBottomOf="@+id/ll_container" />


        <ImageView
            android:id="@+id/iv_pin_tag"
            android:layout_width="@dimen/dp_20"
            android:layout_height="@dimen/dp_20"
            android:layout_marginEnd="@dimen/dp_5"
            android:src="@drawable/iv_pin_tag"
            app:layout_constraintBottom_toBottomOf="@+id/tv_message"
            app:layout_constraintEnd_toStartOf="@+id/ll_read"
            app:layout_constraintTop_toTopOf="@+id/tv_message" />


        <LinearLayout
            android:id="@+id/ll_read"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="@+id/tv_message"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tv_message">

            <com.hjq.shape.view.ShapeTextView
                android:id="@+id/stv_message_count"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/dp_20"
                android:gravity="center"
                android:minWidth="@dimen/dp_20"
                android:paddingHorizontal="@dimen/dp_6"
                android:text="9"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_11"
                app:layout_constraintBottom_toBottomOf="@+id/tv_message"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/tv_message"
                app:shape_radius="@dimen/dp_30"
                app:shape_solidColor="@color/color_E70614" />

            <com.hjq.shape.view.ShapeTextView
                android:id="@+id/stv_message_red"
                android:layout_width="@dimen/dp_10"
                android:layout_height="@dimen/dp_10"
                android:gravity="center"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="@+id/tv_message"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/tv_message"
                app:shape_radius="@dimen/dp_30"
                app:shape_solidColor="@color/color_button" />

        </LinearLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>


    <com.hjq.shape.layout.ShapeLinearLayout
        android:id="@+id/ll_delete"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="center"
        app:shape_radius="@dimen/dp_12"
        app:shape_solidColor="@color/color_FB5150"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/dp_25">

        <ImageView
            android:layout_width="@dimen/dp_30"
            android:layout_height="@dimen/dp_30"
            android:src="@drawable/iv_delete" />


    </com.hjq.shape.layout.ShapeLinearLayout>

</com.chat.lib_common.widget.SwipeMenuLayout>



