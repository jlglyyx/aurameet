<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/dp_15"
    android:layout_marginBottom="@dimen/dp_13"
    xmlns:app="http://schemas.android.com/apk/res-auto">


    <com.google.android.material.imageview.ShapeableImageView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:id="@+id/iv_image"
        android:scaleType="centerCrop"
        app:shapeAppearance="@style/RadiusStyle_5"
        app:layout_constraintDimensionRatio="1:1.3"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>


    <com.hjq.shape.view.ShapeTextView
        android:layout_width="0dp"
        app:shape_radiusInBottomLeft="@dimen/dp_5"
        app:shape_radiusInBottomRight="@dimen/dp_5"
        app:layout_constraintStart_toStartOf="@+id/iv_image"
        app:layout_constraintEnd_toEndOf="@+id/iv_image"
        android:layout_height="wrap_content"
        android:text="Athletic"
        android:gravity="center"
        android:id="@+id/tv_figure"
        android:textColor="@color/white"
        android:textSize="@dimen/sp_15"
        android:paddingVertical="@dimen/dp_8"
        app:shape_solidColor="@color/black_30"
        app:layout_constraintBottom_toBottomOf="@+id/iv_image"
        />

    <ImageView
        app:layout_constraintEnd_toEndOf="@+id/iv_image"
        app:layout_constraintTop_toTopOf="@+id/iv_image"
        android:layout_width="@dimen/dp_30"
        android:layout_height="@dimen/dp_30"
        android:id="@+id/iv_figure_check"
        android:src="@drawable/iv_figure_check"/>

</androidx.constraintlayout.widget.ConstraintLayout>