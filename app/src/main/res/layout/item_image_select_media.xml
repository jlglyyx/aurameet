<?xml version="1.0" encoding="utf-8"?>
<com.hjq.shape.layout.ShapeConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/dp_5"
    app:shape_radius="@dimen/dp_10"
    android:id="@+id/scl_container"
    app:shape_strokeColor="@color/white"
    android:padding="@dimen/dp_2"
    app:shape_strokeSize="@dimen/dp_2">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_image"
        android:layout_width="@dimen/dp_60"
        android:layout_height="@dimen/dp_60"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/RadiusStyle_10"
       />


    <com.hjq.shape.layout.ShapeLinearLayout
        android:id="@+id/ll_destroy_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:shape_solidColor="@color/color_666666"
        android:gravity="center"
        android:visibility="gone"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/dp_10"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shape_radius="@dimen/dp_10">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_error"
            android:layout_width="@dimen/dp_22"
            android:layout_height="@dimen/dp_22"
            android:src="@drawable/iv_crazy_video_error" />

        <TextView
            android:id="@+id/tv_expired"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_8"
            android:gravity="center"
            android:text="Expired"
            android:textColor="@color/white"
            android:textSize="@dimen/sp_10" />

    </com.hjq.shape.layout.ShapeLinearLayout>
</com.hjq.shape.layout.ShapeConstraintLayout>