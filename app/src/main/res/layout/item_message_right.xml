<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/dp_10"
    android:layout_marginVertical="@dimen/dp_5">

    <include
        android:id="@+id/ll_time"
        layout="@layout/item_message_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />



    <com.hjq.shape.view.ShapeTextView
        android:id="@+id/tv_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dp_50"
        android:layout_marginEnd="@dimen/dp_12"
        android:paddingHorizontal="@dimen/dp_15"
        android:paddingVertical="@dimen/dp_12"
        android:text="aaaaaaaaaa"
        android:textColor="@color/color_151515"
        android:textSize="@dimen/sp_16"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ll_time"
        app:layout_constrainedWidth="true"
        app:layout_constraintHorizontal_bias="1"
        app:shape_radius="@dimen/dp_15"
        app:shape_solidColor="@color/white" />


    <ImageView
        android:id="@+id/iv_send_text_message_error"
        android:layout_width="@dimen/dp_24"
        android:layout_height="@dimen/dp_24"
        android:layout_gravity="center"
        android:layout_marginEnd="@dimen/dp_12"
        app:layout_constraintTop_toTopOf="@+id/tv_message"
        app:layout_constraintBottom_toBottomOf="@+id/tv_message"
        app:layout_constraintEnd_toStartOf="@+id/tv_message"
        android:src="@drawable/iv_send_message_error"
        android:visibility="gone" />

    <com.chat.lib_common.widget.LoadImageView
        android:id="@+id/iv_send_message_load"
        android:layout_width="@dimen/dp_24"
        android:layout_height="@dimen/dp_24"
        android:layout_gravity="center"
        android:layout_marginEnd="@dimen/dp_12"
        app:layout_constraintTop_toTopOf="@+id/tv_message"
        app:layout_constraintBottom_toBottomOf="@+id/tv_message"
        app:layout_constraintEnd_toStartOf="@+id/tv_message"
        android:src="@drawable/iv_send_message_load"
        android:visibility="gone" />



    <TextView
        android:id="@+id/tv_error_reason"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reached the limit"
        android:textColor="@color/color_999999"
        android:textSize="@dimen/sp_12"
        app:layout_constraintTop_toBottomOf="@+id/tv_message"
        app:layout_constraintEnd_toEndOf="@+id/tv_message"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constrainedWidth="true"
        android:layout_marginTop="@dimen/dp_6"
        app:layout_constraintHorizontal_bias="1"
        />

</androidx.constraintlayout.widget.ConstraintLayout>

