<?xml version="1.0" encoding="utf-8"?>
<com.hjq.shape.layout.ShapeConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:shape_solidColor="@color/color_4FFF3170"
    android:paddingBottom="@dimen/dp_10"
    app:shape_radius="@dimen/dp_10"
    android:id="@+id/scl_container"
    android:layout_marginEnd="@dimen/dp_15"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.hjq.shape.view.ShapeTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:shape_radiusInTopLeft="@dimen/dp_10"
        app:shape_radiusInBottomRight="@dimen/dp_10"
        app:shape_solidColor="@color/color_FF3170"
        android:textColor="@color/white"
        android:textSize="@dimen/dp_10"
        android:paddingHorizontal="@dimen/dp_7"
        android:text="New"
        android:id="@+id/stv_new"
        android:paddingVertical="@dimen/dp_1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    
    <com.google.android.material.imageview.ShapeableImageView
        android:layout_width="@dimen/dp_55"
        android:layout_height="@dimen/dp_55"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:shapeAppearance="@style/circleStyle"
        app:strokeColor="@color/color_EAA82B"
        app:strokeWidth="@dimen/dp_1_5"
        android:padding="@dimen/dp_1_5"
        android:scaleType="centerCrop"
        android:id="@+id/iv_avatar"
        android:layout_marginTop="@dimen/dp_10"
        android:layout_marginHorizontal="@dimen/dp_15"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.chat.jolt.widget.CarouselImageView
        android:layout_width="@dimen/dp_55"
        android:layout_height="@dimen/dp_55"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:id="@+id/mCarouselImageView"
        android:layout_marginTop="@dimen/dp_10"
        android:layout_marginHorizontal="@dimen/dp_15"
        app:layout_constraintTop_toTopOf="parent"/>


    <TextView
        app:layout_constraintTop_toBottomOf="@+id/iv_avatar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_width="wrap_content"
        android:text="Olijahs,23"
        android:textSize="@dimen/sp_15"
        android:id="@+id/tv_name"
        android:textStyle="bold"
        android:layout_marginTop="@dimen/dp_5"
        android:maxEms="5"
        android:ellipsize="middle"
        android:singleLine="true"
        android:textColor="@color/white"
        android:layout_marginHorizontal="@dimen/dp_5"
        android:layout_height="wrap_content"
        />
    <TextView
        app:layout_constraintTop_toTopOf="@+id/iv_avatar"
        app:layout_constraintStart_toStartOf="@+id/iv_avatar"
        app:layout_constraintEnd_toEndOf="@+id/iv_avatar"
        app:layout_constraintBottom_toBottomOf="@+id/iv_avatar"
        android:layout_width="wrap_content"
        android:text="+1"
        android:id="@+id/tv_add_count"
        android:textSize="@dimen/sp_16"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:layout_height="wrap_content"
        />

    <com.hjq.shape.view.ShapeTextView
        android:id="@+id/stv_message_count"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/dp_20"
        android:gravity="center"
        android:minWidth="@dimen/dp_20"
        android:paddingHorizontal="@dimen/dp_6"
        android:text="9"
        android:textColor="@color/white"
        android:textSize="@dimen/sp_11"
        app:layout_constraintBottom_toBottomOf="@+id/iv_avatar"
        app:layout_constraintEnd_toEndOf="@+id/iv_avatar"
        app:shape_radius="@dimen/dp_30"
        app:shape_solidColor="@color/color_E70614"
        app:shape_strokeColor="@color/white"
        app:shape_strokeSize="@dimen/dp_1_5" />

</com.hjq.shape.layout.ShapeConstraintLayout>