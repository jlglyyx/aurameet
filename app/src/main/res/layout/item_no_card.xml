<?xml version="1.0" encoding="utf-8"?>
<com.hjq.shape.layout.ShapeConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/dp_10"
    android:layout_marginBottom="@dimen/dp_10"
    android:orientation="vertical"
    app:shape_radius="@dimen/dp_15"
>

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_image"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        app:layout_constraintDimensionRatio="1:1.3"
        app:shapeAppearance="@style/RadiusStyle_15" />

    <com.hjq.shape.view.ShapeTextView
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_150"
        app:shape_radius="@dimen/dp_15"
        app:layout_constraintBottom_toBottomOf="parent"
        app:shape_solidGradientEndColor="@color/transparent"
        app:shape_solidGradientOrientation="bottomToTop"
        app:shape_solidGradientStartColor="@color/black_80"/>

    <ImageView
        android:layout_width="@dimen/dp_36"
        android:layout_height="@dimen/dp_36"
        android:layout_marginEnd="@dimen/dp_8"
        android:layout_marginBottom="@dimen/dp_10"
        android:src="@drawable/iv_like"
        android:id="@+id/iv_like"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_8"
        android:layout_marginTop="@dimen/dp_5"
        android:layout_marginBottom="@dimen/dp_5"
        android:ellipsize="end"
        android:singleLine="true"
        android:textColor="@color/white"
        android:textSize="@dimen/sp_16"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/iv_like"
        app:layout_constraintBottom_toTopOf="@+id/ll_container"
        app:layout_constraintStart_toStartOf="parent" />


    <LinearLayout
        android:id="@+id/ll_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/dp_8"
        app:layout_constraintBottom_toBottomOf="@+id/iv_image"
        app:layout_constraintStart_toStartOf="@+id/tv_name">


        <com.hjq.shape.layout.ShapeLinearLayout
            android:id="@+id/sll_online"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/dp_6"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/dp_5"
            android:paddingVertical="@dimen/dp_3"
            app:shape_radius="@dimen/dp_13"
            app:shape_solidColor="#50000000"
            app:shape_strokeSize="@dimen/dp_1">

            <com.hjq.shape.view.ShapeView
                android:id="@+id/sv_online"
                android:layout_width="5dp"
                android:layout_height="5dp"
                app:shape_radius="@dimen/dp_10"
                app:shape_solidColor="@color/color_76E664" />

            <TextView
                android:id="@+id/tv_online"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dp_3"
                android:text="Online"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_10" />


        </com.hjq.shape.layout.ShapeLinearLayout>


        <com.hjq.shape.layout.ShapeLinearLayout
            android:id="@+id/sll_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/dp_5"
            android:paddingVertical="@dimen/dp_3"
            app:shape_radius="@dimen/dp_13"
            app:shape_solidColor="#50000000"
            app:shape_strokeSize="@dimen/dp_1">

            <ImageView
                android:id="@+id/sv_location"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:src="@drawable/iv_location"
                app:tint="@color/color_D97CFF" />

            <TextView
                android:id="@+id/tv_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_10" />


        </com.hjq.shape.layout.ShapeLinearLayout>

    </LinearLayout>




</com.hjq.shape.layout.ShapeConstraintLayout>