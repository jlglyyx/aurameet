<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/dp_15"
    android:layout_marginBottom="@dimen/dp_20"
    android:gravity="center"
    android:orientation="vertical"
    >




    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">


        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_friend_avatar"
            android:layout_width="@dimen/dp_40"
            android:layout_height="@dimen/dp_40"
            android:scaleType="centerCrop"
            android:src="@drawable/iv_conversation_notice"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/RadiusStyle_10" />


        <com.hjq.shape.view.ShapeTextView
            android:id="@+id/tv_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_12"
            android:paddingHorizontal="@dimen/dp_15"
            android:paddingVertical="@dimen/dp_12"
            android:textIsSelectable="true"
            android:text=" Viewing is not supported on this app version."
            android:textColor="@color/color_151515"
            android:textSize="@dimen/sp_16"
            app:shape_radius="@dimen/dp_15"
            app:shape_solidColor="@color/white" />

    </LinearLayout>

</LinearLayout>