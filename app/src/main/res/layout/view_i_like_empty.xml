<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/iv_image"
        android:layout_width="@dimen/dp_120"
        android:layout_height="@dimen/dp_120"
        android:scaleType="centerCrop"
        android:layout_marginTop="@dimen/dp_100"
        android:src="@drawable/iv_i_like_empty"
        />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_25"
        android:text="Check back soon！"
        android:textColor="@color/white"
        android:textSize="@dimen/sp_22"
        android:layout_marginTop="@dimen/dp_16"
        android:textStyle="bold"
        android:gravity="center"
        />
    <TextView
        android:id="@+id/tv_desc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_25"
        android:text="You haven’t liked anyone — begin swiping to discover your type!"
        android:textColor="@color/white"
        android:textSize="@dimen/sp_16"
        android:layout_marginTop="@dimen/dp_10"
        android:gravity="center"
        />
    <com.hjq.shape.view.ShapeTextView
        android:id="@+id/stv_0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_25"
        android:layout_marginTop="@dimen/dp_18"
        android:gravity="center"
        android:paddingVertical="@dimen/dp_20"
        android:text="Go to pick your match"
        android:textColor="@color/firstTextColor"
        android:textSize="@dimen/sp_18"
        android:textStyle="bold"
        app:shape_radius="@dimen/dp_30"
        app:shape_solidGradientStartColor="@color/startGradientColor"
        app:shape_solidGradientEndColor="@color/endGradientColor"
        app:shape_solidPressedColor="@color/pressed_color_light"
        />

    <com.hjq.shape.view.ShapeTextView
        android:id="@+id/stv_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_25"
        android:layout_marginTop="@dimen/dp_18"
        android:gravity="center"
        android:paddingVertical="@dimen/dp_20"
        android:text="Improve your profile"
        android:textColor="@color/white"
        android:textSize="@dimen/sp_18"
        android:textStyle="bold"
        app:shape_radius="@dimen/dp_30"
        app:shape_strokeSize="@dimen/dp_2"
        app:shape_strokeColor="@color/white"
        app:shape_solidPressedColor="@color/pressed_color_light"
        />
</LinearLayout>