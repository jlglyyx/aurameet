<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cl_limit_time"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <ImageView
        android:id="@+id/iv_image"
        android:layout_width="@dimen/dp_66"
        android:layout_height="@dimen/dp_66"
        android:src="@drawable/iv_limit_time_2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.chat.jolt.widget.TimeTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/stv_time"
        android:textColor="@color/white"
        android:textSize="@dimen/sp_10"
        app:shape_radius="@dimen/dp_10"
        app:shape_strokeSize="@dimen/dp_1"
        app:shape_strokeColor="@color/white"
        android:text="00:00:00"
        android:layout_marginTop="-20dp"
        android:paddingVertical="@dimen/dp_3"
        android:paddingHorizontal="@dimen/dp_6"
        app:shape_solidColor="@color/color_6F009B"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/iv_image"/>

</androidx.constraintlayout.widget.ConstraintLayout>