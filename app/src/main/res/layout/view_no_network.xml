<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:gravity="center"
    android:layout_width="match_parent"
    android:clickable="true"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/iv_image"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="centerCrop"
        android:src="@drawable/iv_no_net"
        android:layout_marginBottom="@dimen/dp_15"
        />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_25"
        android:text="No Internet"
        android:textColor="@color/white"
        android:textSize="@dimen/sp_20"
        android:layout_marginBottom="@dimen/dp_5"
        android:textStyle="bold"
        android:gravity="center"
        android:visibility="gone"
        />


    <TextView
        android:id="@+id/tv_desc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_5"
        android:text="Oops! Network error. Please checkyour networks status and try againlater"
        android:textColor="@color/color_999999"
        android:textSize="@dimen/sp_16"
        android:layout_marginHorizontal="@dimen/dp_25"
        android:gravity="center"
        />
    <com.hjq.shape.view.ShapeTextView
        android:id="@+id/stv_confirm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_25"
        android:layout_marginTop="@dimen/dp_30"
        android:gravity="center"
        android:paddingVertical="@dimen/dp_17"
        android:text="Retry"
        android:textColor="@color/white"
        android:textSize="@dimen/sp_18"
        android:textStyle="bold"
        app:shape_radius="@dimen/dp_29"
        app:shape_solidPressedColor="@color/pressed_color_light"
        app:shape_solidColor="@color/color_EAA82B"
        />
</LinearLayout>