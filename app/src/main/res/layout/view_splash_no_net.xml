<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:gravity="center"
    android:layout_width="match_parent"
    android:clickable="true"
    android:background="@color/color_F8F1E9"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/iv_image"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="centerCrop"
        android:src="@drawable/iv_no_net"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No Connection"
        android:textColor="@color/color_151515"
        android:textSize="@dimen/sp_20"
        android:fontFamily="@font/arial_black"
        android:layout_marginHorizontal="@dimen/dp_25"
        android:layout_marginTop="@dimen/dp_20"
        android:gravity="center"
        />
    <TextView
        android:id="@+id/tv_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Oops! Network error. Please checkyour networks status and try againlater"
        android:textColor="@color/color_666666"
        android:textSize="@dimen/sp_16"
        android:layout_marginHorizontal="@dimen/dp_25"
        android:layout_marginTop="@dimen/dp_15"
        android:gravity="center"
        />
    <com.hjq.shape.view.ShapeTextView
        android:id="@+id/stv_next"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_25"
        android:layout_marginTop="@dimen/dp_30"
        android:gravity="center"
        android:paddingVertical="@dimen/dp_17"
        android:text="Try Again"
        android:textColor="@color/white"
        android:textSize="@dimen/sp_18"
        android:textStyle="bold"
        app:shape_radius="@dimen/dp_10"
        app:shape_solidPressedColor="@color/pressed_color_light"
        app:shape_solidColor="@color/color_button"
        />
</LinearLayout>