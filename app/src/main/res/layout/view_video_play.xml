<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <androidx.media3.ui.PlayerView
        android:id="@+id/play_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:keepScreenOn="true"
        app:layout_constraintTop_toTopOf="parent"
        app:resize_mode="fit"
        app:surface_type="texture_view"
        app:use_controller="false" />


    <ImageView
        android:id="@+id/iv_image_cover"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/iv_play"
        android:layout_width="@dimen/dp_60"
        android:layout_height="@dimen/dp_60"
        android:visibility="gone"
        android:src="@drawable/iv_pause"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="@dimen/dp_15"
        android:id="@+id/ll_menu"
        android:background="@color/black_30"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/iv_progress_play"
            android:layout_width="@dimen/dp_20"
            android:layout_height="@dimen/dp_20"
            android:src="@drawable/iv_pause"/>
        <TextView
            android:id="@+id/tv_current_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:layout_marginStart="@dimen/dp_15"
            android:textColor="@color/white"
            android:layout_marginEnd="@dimen/dp_2"
            android:textStyle="bold"
            android:textSize="@dimen/sp_14" />

        <androidx.appcompat.widget.AppCompatSeekBar
            android:id="@+id/mSeekBarProgress"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="@dimen/dp_20"
            android:paddingVertical="@dimen/dp_8"
            android:thumbOffset="@dimen/dp_0"
            android:splitTrack="false"
            android:clipToPadding="false"
            android:progress="0"
            android:progressDrawable="@drawable/layer_video_progress"
            android:thumb="@drawable/shape_video_thumb"/>

        <TextView
            android:id="@+id/tv_count_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textStyle="bold"
            android:layout_marginStart="@dimen/dp_2"
            android:textColor="@color/white"
            android:textSize="@dimen/sp_14" />
    </LinearLayout>





</androidx.constraintlayout.widget.ConstraintLayout>